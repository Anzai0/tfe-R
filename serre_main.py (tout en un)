}
firebase = pyrebase.initialize_app(firebase_config)
auth_fb  = firebase.auth()
db       = firebase.database()

CONFIG_FILE = "config.json"

# ─── Config locale ────────────────────────────────────────────────────────────
def charger_config():
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            return json.load(f)
    return None

def sauvegarder_config(email, password):
    with open(CONFIG_FILE, "w") as f:
        json.dump({"email": email, "password": password}, f)

# ─── Firebase Auth ────────────────────────────────────────────────────────────
def connect_firebase():
    config = charger_config()
    if config:
        try:
            user = auth_fb.sign_in_with_email_and_password(
                config["email"], config["password"])
            uid = user["localId"]
            print(f"[Firebase] Connecté : {config['email']} (uid={uid})")
            return uid
        except Exception as e:
            print(f"[Firebase] Erreur connexion: {e}")

    # Saisie manuelle si pas de config
    email    = input("Email Firebase : ").strip()
    password = input("Mot de passe   : ").strip()
    try:
        user = auth_fb.sign_in_with_email_and_password(email, password)
        uid  = user["localId"]
        sauvegarder_config(email, password)
        print(f"[Firebase] Connecté (uid={uid})")
        return uid
    except Exception as e:
        print(f"[Firebase] Échec auth: {e}")
        return None

# ─── Firebase helpers ─────────────────────────────────────────────────────────
def envoyer_firebase(uid, temp, hum, sol, pluie, etat_pompe, etat_ventilo):
    try:
        data = {
            "temperature":  temp  if temp is not None else 0,
            "humidite_air": hum   if hum  is not None else 0,
            "humidite_sol": sol   if sol  is not None else 0,
            "pluie":        bool(pluie),
            "pompe":        etat_pompe   == "ON",
            "ventilateur":  etat_ventilo == "ON",
            "timestamp":    time.strftime("%Y-%m-%d %H:%M:%S")
        }
        db.child("capteurs").child(uid).set(data)
        print("[Firebase] Données envoyées OK")
    except Exception as e:
        print(f"[Firebase] Erreur envoi: {e}")

def lire_commandes_firebase(uid):
    try:
        cmds = db.child("commandes").child(uid).get().val()
        return cmds if cmds else {}
    except Exception as e:
        print(f"[Firebase] Erreur lecture commandes: {e}")
        return {}

def reset_commandes_firebase(uid):
    try:
        db.child("commandes").child(uid).set({"pompe": False, "ventilateur": False})
        print("[Firebase] Commandes réinitialisées")
    except Exception as e:
        print(f"[Firebase] Erreur reset: {e}")

def lire_config_plante(uid):
    """Lit les seuils que l'utilisateur a définis depuis Tkinter."""
    try:
        config = db.child("config_plante").child(uid).get().val()
        if config:
            print(f"[Config] Plante: {config.get('nom')} | "
                  f"TempMax: {config.get('temp_max')}°C | "
                  f"SolMin: {config.get('eau_min')}%")
            return config
        return None
    except Exception as e:
        print(f"[Firebase] Erreur lecture config plante: {e}")
        return None

# ─── LCD sécurisé ─────────────────────────────────────────────────────────────
def lcd_write_safe(lcd_obj, line1="", line2=""):
    try:
        lcd_obj.clear()
        lcd_obj.write_string(str(line1)[:16])
        if line2:
            lcd_obj.cursor_pos = (1, 0)
            lcd_obj.write_string(str(line2)[:16])
    except OSError as e:
        print(f"[LCD] Erreur I2C: {e} — tentative réinit...")
        try:
            lcd_obj = CharLCD('PCF8574', 0x27, cols=16, rows=2)
        except Exception as ex:
            print(f"[LCD] Réinit échouée: {ex}")
    return lcd_obj

# ─── Matériel ──────────────────────────────────────────────────────────────────
lcd = CharLCD('PCF8574', 0x27, cols=16, rows=2)
dht = adafruit_dht.DHT11(board.D17, use_pulseio=False)
time.sleep(2)

pompe = digitalio.DigitalInOut(board.D18)
pompe.direction = digitalio.Direction.OUTPUT

ventilateur = digitalio.DigitalInOut(board.D23)
ventilateur.direction = digitalio.Direction.OUTPUT

buzzer = TonalBuzzer(27)

def init_ads():
    i2c = busio.I2C(board.SCL, board.SDA)
    ads = ADS.ADS1115(i2c)
    return AnalogIn(ads, 0), AnalogIn(ads, 1)

capteur_pluie, capteur_sol = init_ads()

# ─── Variables ────────────────────────────────────────────────────────────────
ecran            = 0
temp_last        = None
hum_last         = None
sol_last         = None
pluie_last       = False
firebase_counter = 0
config_counter   = 0

# Seuils par défaut (écrasés dès que l'utilisateur configure une plante)
seuil_temp_max = 30.0
seuil_eau_min  = 30.0
nom_plante     = "Aucune"

cmd_pompe_manuelle   = None
cmd_ventilo_manuelle = None

# ─── Connexion Firebase ────────────────────────────────────────────────────────
uid = connect_firebase()
if uid:
    reset_commandes_firebase(uid)

    # Lecture initiale des seuils de la plante
    config_init = lire_config_plante(uid)
    if config_init:
        seuil_temp_max = float(config_init.get("temp_max", 30.0))
        seuil_eau_min  = float(config_init.get("eau_min",  30.0))
        nom_plante     = config_init.get("nom", "Inconnue")
        print(f"[Init] Seuils chargés — TempMax={seuil_temp_max}°C | "
              f"SolMin={seuil_eau_min}%")
else:
    print("[WARN] Mode local uniquement (pas de Firebase)")

# ─── Boucle principale ────────────────────────────────────────────────────────
try:
    while True:

        # ── Relit les seuils utilisateur toutes les 10 boucles (~20s) ──────
        config_counter += 1
        if config_counter >= 10 and uid:
            config_counter = 0
            config = lire_config_plante(uid)
            if config:
                nouveau_temp_max = float(config.get("temp_max", seuil_temp_max))
                nouveau_eau_min  = float(config.get("eau_min",  seuil_eau_min))
                nouveau_nom      = config.get("nom", nom_plante)

                if (nouveau_temp_max != seuil_temp_max or
                        nouveau_eau_min != seuil_eau_min or
                        nouveau_nom != nom_plante):
                    seuil_temp_max = nouveau_temp_max
                    seuil_eau_min  = nouveau_eau_min
                    nom_plante     = nouveau_nom
                    print(f"[Seuils] Mis à jour — Plante: {nom_plante} | "
                          f"TempMax={seuil_temp_max}°C | "
                          f"SolMin={seuil_eau_min}%")

        # ── Lecture DHT11 ────────────────────────────────────────────────────
        try:
            temp = dht.temperature
            hum  = dht.humidity
            temp_last = temp
            hum_last  = hum
        except Exception:
            temp = temp_last
            hum  = hum_last

        # ── Lecture ADS1115 ──────────────────────────────────────────────────
        try:
            valeur_pluie    = capteur_pluie.value
            valeur_sol      = capteur_sol.value
            pourcentage_sol = round((1 - valeur_sol / 32767) * 100, 1)
            pluie           = valeur_pluie < 26500
            sol_last        = pourcentage_sol
            pluie_last      = pluie
        except Exception:
            try:
                capteur_pluie, capteur_sol = init_ads()
            except:
                pass
            pourcentage_sol = sol_last
            pluie           = pluie_last

        # ── Lecture commandes manuelles Firebase ─────────────────────────────
        if uid:
            cmds = lire_commandes_firebase(uid)
            if "pompe" in cmds:
                cmd_pompe_manuelle = bool(cmds["pompe"])
            if "ventilateur" in cmds:
                cmd_ventilo_manuelle = bool(cmds["ventilateur"])

        # ── Gestion Pompe selon seuil utilisateur ────────────────────────────
        if cmd_pompe_manuelle is not None:
            pompe.value = cmd_pompe_manuelle
            etat_pompe  = "ON" if cmd_pompe_manuelle else "OFF"
        else:
            if pourcentage_sol is not None and pourcentage_sol < seuil_eau_min and not pluie:
                pompe.value = True
                etat_pompe  = "ON"
                print(f"[Pompe] AUTO ON — Sol: {pourcentage_sol}% < seuil: {seuil_eau_min}%")
            else:
                pompe.value = False
                etat_pompe  = "OFF"

        # ── Gestion Ventilateur selon seuil utilisateur ──────────────────────
        if cmd_ventilo_manuelle is not None:
            ventilateur.value = cmd_ventilo_manuelle
            etat_ventilo      = "ON" if cmd_ventilo_manuelle else "OFF"
        else:
            if temp is not None and temp > seuil_temp_max:
                ventilateur.value = True
                etat_ventilo      = "ON"
                print(f"[Ventilo] AUTO ON — Temp: {temp}°C > seuil: {seuil_temp_max}°C")
            else:
                ventilateur.value = False
                etat_ventilo      = "OFF"

        # ── Buzzer si température critique ───────────────────────────────────
        if temp is not None and temp > (seuil_temp_max + 5):
            buzzer.play(Tone(2000))
            time.sleep(0.5)
            buzzer.stop()
        else:
            buzzer.stop()

        # ── Envoi Firebase toutes les 6 boucles (~12s) ───────────────────────
        firebase_counter += 1
        if firebase_counter >= 6 and uid:
            firebase_counter = 0
            envoyer_firebase(uid, temp, hum, pourcentage_sol,
                             pluie, etat_pompe, etat_ventilo)

        # ── LCD ──────────────────────────────────────────────────────────────
        if ecran == 0:
            lcd = lcd_write_safe(lcd,
                f"T:{temp:.1f}C" if temp is not None else "T:--",
                f"Hum:{hum:.1f}%" if hum is not None else "H:--"
            )
        elif ecran == 1:
            lcd = lcd_write_safe(lcd,
                f"Sol:{pourcentage_sol}%" if pourcentage_sol is not None else "Sol:--",
                "PLUIE!" if pluie else "Pas de pluie"
            )
        elif ecran == 2:
            lcd = lcd_write_safe(lcd,
                f"P:{etat_pompe} V:{etat_ventilo}",
                f"T:{temp:.1f}C S:{pourcentage_sol}%"
                if temp is not None and pourcentage_sol is not None else "--"
            )

        ecran = (ecran + 1) % 3
        time.sleep(2)

finally:
    # ── Tout éteindre proprement ──────────────────────────────────────────
    pompe.value = False
    pompe.deinit()
    ventilateur.value = False
    ventilateur.deinit()
    buzzer.stop()
    dht.exit()
    try:
        lcd.clear()
    except:
        pass
    if uid:
        reset_commandes_firebase(uid)
    print("Système arrêté")
