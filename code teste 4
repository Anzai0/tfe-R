    def _charger_historique_stats(self):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("SELECT timestamp, temperature, humidite_air, humidite_sol, pluie FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 5", (self.uid,))
            rows = cur.fetchall()
            
            for item in self.table_stats.get_children():
                self.table_stats.delete(item)
                
            for index, r in enumerate(rows):
                tag = "pair" if index % 2 == 0 else "impair"
                date_str = r[0].strftime("%d/%m/%Y %H:%M:%S") if r[0] else "--"
                pluie_str = "Oui 🌧️" if r[4] else "Non ☀️"
                self.table_stats.insert("", "end", values=(date_str, f"{r[1]} °C", f"{r[2]} %", f"{r[3]} %", pluie_str), tags=(tag,))
                
            cur.close(); conn.close()
        except:
            pass
        self.after(10000, self._charger_historique_stats)

    def _render_plantes(self):
