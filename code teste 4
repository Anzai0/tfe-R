# --- COMPOSANT : BOUTON INTERRUPTEUR (TOGGLE SWITCH ANIMÉ AVEC TEXTE) ---
class ToggleSwitch(tk.Canvas):
    def __init__(self, parent, command=None, width=75, height=30):
        super().__init__(parent, width=width, height=height, bg=C["bg_input"], bd=0, highlightthickness=0, cursor="hand2")
        self.command = command
        self.state = False
        self.width = width
        self.height = height
        
        self.radius = height // 2
        self.circle_radius = self.radius - 3
        
        self.x_off = self.radius
        self.x_on = width - self.radius
        self.current_x = self.x_off
        
        self.bind("<Button-1>", self._toggle)
        self._draw()

    def _draw(self):
        self.delete("all")
        bg_color = C["accent"] if self.state else C["danger"]
        
        # Fond du bouton (forme pilule)
        self.create_oval(0, 0, self.height, self.height, fill=bg_color, outline="")
        self.create_oval(self.width - self.height, 0, self.width, self.height, fill=bg_color, outline="")
        self.create_rectangle(self.radius, 0, self.width - self.radius, self.height, fill=bg_color, outline="")
        
        # Texte ON / OFF intégré
        if self.state:
            self.create_text(self.radius + 8, self.radius, text="ON", fill="#FFFFFF", font=("Segoe UI", 9, "bold"), anchor="w")
        else:
            self.create_text(self.width - self.radius - 8, self.radius, text="OFF", fill="#FFFFFF", font=("Segoe UI", 9, "bold"), anchor="e")
        
        # Curseur coulissant blanc
        self.create_oval(self.current_x - self.circle_radius, self.radius - self.circle_radius,
                         self.current_x + self.circle_radius, self.radius + self.circle_radius,
                         fill="#FFFFFF", outline="")

    def _toggle(self, event):
        self.state = not self.state
        self._animate()
        if self.command:
            self.command(self.state)

    def _animate(self):
        target_x = self.x_on if self.state else self.x_off
        steps = 4
        diff = (target_x - self.current_x) / steps
        
        def step(count):
            if count < steps:
                self.current_x += diff
                self._draw()
                self.after(20, lambda: step(count + 1))
            else:
                self.current_x = target_x
                self._draw()
                
        step(0)

    def set_state(self, state):
        if self.state != state:
            self.state = state
            self.current_x = self.x_on if state else self.x_off
            self._draw()

