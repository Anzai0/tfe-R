        if len(self.plantes) < 3:
            btn_add = tk.Button(top_bar, text="+ Ajouter une plante", command=self._popup_plante)
            style_btn(btn_add, bg=C["accent"], fg=C["bg_main"])
            btn_add.pack(side="right", padx=5)

        if not self.plantes:
            tk.Label(self.plant_section, text="// Aucune plante enregistrée.", font=("Segoe UI", 10, "italic"), bg=C["bg_card"], fg=C["text_muted"]).pack(pady=20)
            return

        for p in self.plantes:
            is_active = self.plante_active and self.plante_active["nom"] == p["nom"]
            bg_item = C["bg_input"] if is_active else C["bg_card"]
            b_color = C["accent"] if is_active else C["border"]

            item = tk.Frame(self.plant_section, bg=bg_item, highlightthickness=1, highlightbackground=b_color, padx=15, pady=8)
            item.pack(fill="x", pady=4)

            lbl_name = tk.Label(item, text=p["nom"].upper(), font=("Segoe UI", 11, "bold"), bg=bg_item, fg=C["text_main"] if not is_active else C["accent"])
            lbl_name.pack(side="left")

            if is_active:
                tk.Label(item, text="[ ACTIF ]", font=("Segoe UI", 8, "bold"), bg=bg_item, fg=C["accent"]).pack(side="left", padx=15)

            badge_box = tk.Frame(item, bg=bg_item)
            badge_box.pack(side="right")

            for txt, c in [(f"MAX T°: {p['temp_max']}°C", C["info"]), (f"MIN SOL: {p['eau_min']}%", C["warning"])]:
                b = tk.Frame(badge_box, bg=C["bg_main"], padx=8, pady=4, highlightthickness=1, highlightbackground=C["border"])
                b.pack(side="left", padx=5)
                tk.Label(b, text=txt, font=("Segoe UI", 8), bg=C["bg_main"], fg=C["text_main"]).pack()

            if not is_active:
                b_sel = tk.Button(badge_box, text="SUIVRE", command=lambda pl=p: self._select_plante(pl))
                style_btn(b_sel, bg=C["border"], fg=C["text_main"])
                b_sel.pack(side="left", padx=10)
            
            b_del = tk.Button(badge_box, text="X", command=lambda pl=p: self._suppr_plante(pl))
            style_btn(b_del, bg=C["danger"], fg=C["text_main"])
            b_del.pack(side="left", padx=5)

    def _select_plante(self, p):
        self.plante_active = p
        self._render_plantes()
        self._log("INFO", f"Plante sélectionnée : [{p['nom'].upper()}]")

    def _suppr_plante(self, p):
        if not messagebox.askyesno("Confirmation", f"Supprimer la plante '{p['nom']}' ?"): return
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("DELETE FROM plantes WHERE uid=%s AND nom=%s", (self.uid, p["nom"]))
            conn.commit(); cur.close(); conn.close()
            self.plantes = [x for x in self.plantes if x["nom"] != p["nom"]]
            if self.plante_active and self.plante_active["nom"] == p["nom"]:
                self.plante_active = self.plantes[0] if self.plantes else None
            self._render_plantes()
            self._log("WARN", f"Plante supprimée : '{p['nom']}'")
        except Exception as e:
            self._log("ERR", f"Erreur SQL : {e}")

    def _popup_plante(self):
        pop = tk.Toplevel(self)
        pop.title("Configuration")
        pop.configure(bg=C["bg_main"])
        pop.geometry("380x420")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(pop, text="AJOUTER UNE NOUVELLE PLANTE", font=("Segoe UI", 12, "bold"), bg=C["bg_main"], fg=C["text_main"]).pack(pady=(25, 15))
        
        f_fields = tk.Frame(pop, bg=C["bg_card"], padx=20, pady=20, highlightthickness=1, highlightbackground=C["border"])
        f_fields.pack(fill="both", expand=True, padx=25, pady=(0, 25))

        fields = [("NOM DE LA PLANTE", "nom", ""), ("TEMPÉRATURE MAXIMALE (°C)", "t_max", "30"), ("HUMIDITÉ DU SOL MINIMALE (%)", "e_min", "40")]
        entries = {}

        for label, key, default in fields:
            tk.Label(f_fields, text=label, font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w", pady=(5,0))
            e = tk.Entry(f_fields)
            style_entry(e)
            e.insert(0, default)
            e.pack(fill="x", pady=(4, 12), ipady=6)
            entries[key] = e

        lbl_err = tk.Label(f_fields, text="", font=("Segoe UI", 9), bg=C["bg_card"], fg=C["danger"])
        lbl_err.pack()

        def valider():
            nom = entries["nom"].get().strip()
            if not nom: lbl_err.configure(text="Nom requis."); return
            try:
                tm = float(entries["t_max"].get())
                em = float(entries["e_min"].get())
            except: lbl_err.configure(text="Valeurs numériques incorrectes."); return

            try:
                conn = get_db(); cur = conn.cursor()
                cur.execute("INSERT INTO plantes (uid,nom,temp_max,humidite_min,eau_min) VALUES (%s,%s,%s,%s,%s)", (self.uid, nom, tm, 0.0, em))
                conn.commit(); cur.close(); conn.close()
                self.plantes.append({"nom": nom, "temp_max": tm, "humidite_min": 0.0, "eau_min": em})
                if not self.plante_active: self.plante_active = self.plantes[0]
                self._render_plantes()
                self._log("OK", f"Plante enregistrée : {nom}")
                pop.destroy()
            except Exception as ex:
                lbl_err.configure(text=f"Erreur DB : {ex}")

        btn_save = tk.Button(f_fields, text="ENREGISTRER", command=valider)
        style_btn(btn_save)
        btn_save.pack(fill="x", ipady=6, pady=(10, 0))

    def _api_pompe(self, state):
        self.pompe_on = state
        self._log("OK" if state else "WARN", f"Manuel -> Pompe : {'ON' if state else 'OFF'}")
        threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"pompe": state}), daemon=True).start()

    def _api_ventilo(self, state):
        self.ventilo_on = state
        self._log("OK" if state else "WARN", f"Manuel -> Ventilation : {'ON' if state else 'OFF'}")
        threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": state}), daemon=True).start()

    def _rafraichir_donnees(self):
        def tache():
            try:
                d = db.child("capteurs").child(self.uid).get().val()
                if d:
                    self.after(0, self._process_telemetrie, d)
                else:
                    self._log("WARN", "En attente des données du Raspberry Pi...")
            except Exception as e:
                self._log("ERR", f"Erreur liaison Cloud : {e}")
            self.after(5000, self._rafraichir_donnees)
        threading.Thread(target=tache, daemon=True).start()

    def _process_telemetrie(self, data):
        temp = data.get("temperature", 0.0)
        hum = data.get("humidite_air", 0.0)
        sol = data.get("humidite_sol", 0.0)
        pluie = data.get("pluie", False)

        for key, val in [("temp", temp), ("hum", hum), ("sol", sol)]:
            lbl, bar, unit, _ = self._cards_widgets[key]
            lbl.configure(text=f"{val} {unit}")
            ratio = min(max(val / 100.0 if key != "temp" else val / 50.0, 0.0), 1.0)
            bar.place(relwidth=ratio)
            
        lbl, bar, _, _ = self._cards_widgets["pluie"]
        lbl.configure(text="OUI" if pluie else "NON", fg=C["info"] if pluie else C["text_main"])
        bar.place(relwidth=1.0 if pluie else 0.05)

        self._log("INFO", f"Données -> T°: {temp}°C | Sol: {sol}% | Pluie: {'Oui' if pluie else 'Non'}")

        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("INSERT INTO capteurs (uid,temperature,humidite_air,humidite_sol,pluie) VALUES (%s,%s,%s,%s,%s)", (self.uid, temp, hum, sol, pluie))
            conn.commit(); cur.close(); conn.close()
        except Exception as e:
            self._log("ERR", f"Erreur MariaDB : {e}")

        if self.plante_active:
            if sol < self.plante_active["eau_min"] and not self.pompe_on:
                self._log("WARN", f"Sol sec ({sol}% < {self.plante_active['eau_min']}%). Pompe activée.")
                self.pompe_on = True
                self.toggle_pompe.set_state(True)
                db.child("commandes").child(self.uid).update({"pompe": True})
            elif sol >= self.plante_active["eau_min"] + 10 and self.pompe_on:
                self._log("OK", f"Humidité sol OK ({sol}%). Pompe arrêtée.")
                self.pompe_on = False
                self.toggle_pompe.set_state(False)
                db.child("commandes").child(self.uid).update({"pompe": False})

            if temp > self.plante_active["temp_max"] and not self.ventilo_on:
                self._log("WARN", f"Surchauffe ({temp}°C > {self.plante_active['temp_max']}°C). Ventilateur activé.")
                self.ventilo_on = True
                self.toggle_ventilo.set_state(True)
                db.child("commandes").child(self.uid).update({"ventilateur": True})
            elif temp <= self.plante_active["temp_max"] - 2 and self.ventilo_on:
                self._log("OK", f"Température stabilisée ({temp}°C). Ventilateur arrêté.")
                self.ventilo_on = False
                self.toggle_ventilo.set_state(False)
                db.child("commandes").child(self.uid).update({"ventilateur": False})

    def _log(self, level, msg):
        self.after(0, self._log_ui, level, msg)

    def _log_ui(self, level, msg):
        self.console.configure(state="normal")
        ts = time.strftime("%H:%M:%S")
        self.console.insert("end", f"[{ts}] ", "TEXT_MUTED")
        self.console.insert("end", f"[{level}] ", level)
        self.console.insert("end", f"{msg}\n")
        self.console.configure(state="disabled")
        self.console.see("end")

    def _clear_console(self):
        self.console.configure(state="normal")
        self.console.delete("1.0", "end")
        self.console.configure(state="disabled")

# --- APPLICATION MASTER ---
class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("Serre Connectée Management System")
        self.fen.geometry("1080x840")  
        self.fen.configure(bg=C["bg_main"])
        self.fen.resizable(False, False)
        
        init_db()
        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page: self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page: self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def run(self):
        self.fen.mainloop()

if __name__ == "__main__":
    App().run()
