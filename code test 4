                                 padx=20, pady=10)
        btn_connexion.pack(side="left", padx=5)
        
        btn_inscription = tk.Button(frame_btns, text="✍️ Inscription",
                                   command=self._inscription,
                                   font=("Arial", 12, "bold"),
