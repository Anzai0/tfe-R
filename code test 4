    def _connexion(self):
        email = self.entry_email.get()
        password = self.entry_password.get()
        
        if not email or not password:
            messagebox.showerror("Erreur", "Remplissez tous les champs")
            return
        
        def _auth():
            try:
                user = auth_fb.sign_in_with_email_and_password(email, password)
                self.uid = user["localId"]
                self.email = email
                self.after(0, lambda: self.callback_dashboard(self.uid, self.email))
            except Exception as e:
                self.after(0, lambda: messagebox.showerror("Erreur", f"Connexion échouée: {str(e)[:100]}"))
        
        threading.Thread(target=_auth, daemon=True).start()
    
    def _inscription(self):
        email = self.entry_email.get()
        password = self.entry_password.get()
        
        if not email or not password:
            messagebox.showerror("Erreur", "Remplissez tous les champs")
            return
        
        def _auth():
            try:
                user = auth_fb.create_user_with_email_and_password(email, password)
                self.uid = user["localId"]
                self.email = email
                self.after(0, lambda: messagebox.showinfo("Succès", "Inscription réussie!"))
                self.after(500, lambda: self.callback_dashboard(self.uid, self.email))
            except Exception as e:
                self.after(0, lambda: messagebox.showerror("Erreur", f"Inscription échouée: {str(e)[:100]}"))
        
        threading.Thread(target=_auth, daemon=True).start()

