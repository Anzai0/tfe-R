    # ─── PLANTES ───────────────────────────────────────────────────────────────
    def _charger_plantes(self):
        """Charge les plantes depuis Firebase"""
        def _fetch():
            try:
                data = db.child("plantes").child(self.uid).get().val()
                if data:
                    self.plantes = data
                    self.after(0, self._afficher_plantes)
                else:
                    self.plantes = {}
                    self.after(0, lambda: self._log("INFO", "Aucune plante trouvée"))
            except Exception as e:
                self.after(0, lambda: self._log("ERR", f"Erreur plantes: {e}"))
        
        threading.Thread(target=_fetch, daemon=True).start()
    
    def _afficher_plantes(self):
        """Affiche les plantes dans la liste"""
        # Nettoyer
        for widget in self.frame_liste_plantes.winfo_children():
            widget.destroy()
        
        if not self.plantes:
            tk.Label(self.frame_liste_plantes, text="Aucune plante", 
                    font=("Arial", 10), fg=C["text"], bg=C["bg_card"]).pack(pady=20)
            return
        
        for nom, data in self.plantes.items():
            btn = tk.Button(self.frame_liste_plantes, text=f"🌱 {nom}",
                          command=lambda n=nom: self._selectionner_plante(n),
                          font=("Arial", 10, "bold"), bg=C["accent"],
                          fg="white", relief="flat", padx=10, pady=8,
                          width=25)
            btn.pack(fill="x", pady=3)
    
    def _selectionner_plante(self, nom):
        """Sélectionne une plante et met à jour serre_main.py"""
        self.plante_selectionnee = nom
        plante_data = self.plantes[nom]
        
        # Envoyer à Firebase pour que serre_main.py lise
        try:
            db.child("config_plante").child(self.uid).update({
                "nom": nom,
                "temp_max": float(plante_data.get("temp_max", 30)),
                "eau_min": float(plante_data.get("eau_min", 40))
            })
            self._log("OK", f"Plante sélectionnée: {nom}")
        except Exception as e:
            self._log("ERR", f"Erreur sélection plante: {e}")
    
