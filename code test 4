    def _build(self):
        # Centrage vertical
        self.rowconfigure(0, weight=1)
        self.columnconfigure(0, weight=1)

        container = tk.Frame(self, bg=C["bg_card"],
                             highlightthickness=1,
                             highlightbackground=C["border"],
                             padx=50, pady=40)
        container.grid(row=0, column=0)

        # Logo / Titre
        tk.Label(container, text="🌿", font=("Segoe UI", 48),
                 bg=C["bg_card"], fg=C["accent"]).pack()
        self.lbl_title = tk.Label(container, text="Connexion",
                                  font=("Segoe UI", 22, "bold"),
                                  bg=C["bg_card"], fg=C["text_main"])
        self.lbl_title.pack(pady=(0, 30))

        # Email
        tk.Label(container, text="Email", font=("Segoe UI", 9, "bold"),
                 bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_email = tk.Entry(container, width=32)
        style_entry(self.e_email)
        self.e_email.pack(fill="x", ipady=8, pady=(4, 16))

        # Mot de passe
        tk.Label(container, text="Mot de passe", font=("Segoe UI", 9, "bold"),
                 bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_mdp = tk.Entry(container, width=32, show="•")
        style_entry(self.e_mdp)
        self.e_mdp.pack(fill="x", ipady=8, pady=(4, 24))

        # Bouton principal
        self.btn_submit = tk.Button(container, text="Se connecter",
                                    command=self._action)
        style_btn(self.btn_submit)
        self.btn_submit.pack(fill="x", ipady=10, pady=(0, 16))

        # Switcher mode
        self.btn_switch = tk.Button(container,
                                    text="Pas de compte ? Créer un compte",
                                    bg=C["bg_card"], fg=C["info"], bd=0,
                                    font=("Segoe UI", 9, "underline"),
                                    cursor="hand2",
                                    activebackground=C["bg_card"],
                                    activeforeground=C["text_main"],
                                    command=self._toggle_mode)
        self.btn_switch.pack()

        self.lbl_msg = tk.Label(container, text="",
                                font=("Segoe UI", 9),
                                bg=C["bg_card"], fg=C["danger"])
        self.lbl_msg.pack(pady=(10, 0))

    def _toggle_mode(self):
        if self.mode == "connexion":
            self.mode = "inscription"
            self.lbl_title.configure(text="Inscription")
            self.btn_submit.configure(text="Créer mon compte")
            self.btn_switch.configure(text="Déjà inscrit ? Se connecter")
        else:
            self.mode = "connexion"
            self.lbl_title.configure(text="Connexion")
            self.btn_submit.configure(text="Se connecter")
            self.btn_switch.configure(text="Pas de compte ? Créer un compte")

    def _action(self):
        email = self.e_email.get().strip()
        mdp   = self.e_mdp.get().strip()
        if not email or not mdp:
            self.lbl_msg.configure(text="Veuillez remplir tous les champs.")
            return
        self.btn_submit.configure(state="disabled", text="Chargement...")

        def tache():
            try:
                if self.mode == "connexion":
                    user = auth.sign_in_with_email_and_password(email, mdp)
                else:
                    user = auth.create_user_with_email_and_password(email, mdp)
                uid = user["localId"]
                self.after(0, lambda: self.on_conn(uid, email))
            except Exception as e:
                s   = str(e)
                msg = "Erreur d'authentification"
                if "EMAIL_EXISTS"    in s: msg = "Cet email est déjà utilisé"
                elif "WEAK_PASSWORD" in s: msg = "Mot de passe trop court (6 car. min)"
                elif "INVALID_EMAIL" in s: msg = "Format d'email invalide"
                elif "EMAIL_NOT_FOUND" in s or "INVALID_PASSWORD" in s:
                    msg = "Identifiants incorrects"
                self.after(0, lambda: [
                    self.lbl_msg.configure(text=msg),
                    self.btn_submit.configure(
                        state="normal",
                        text="Se connecter" if self.mode == "connexion" else "Créer mon compte"
                    )
                ])
        threading.Thread(target=tache, daemon=True).start()

