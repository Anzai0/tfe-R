    def _rafraichir_donnees(self):
        def _fetch():
            try:
                data = db.child("capteurs").child(self.uid).get().val()
                if data:
                    self.after(0, self._mettre_a_jour_ui, data)
            except Exception as e:
                print(f"[Firebase] Erreur lecture capteurs: {e}")
        threading.Thread(target=_fetch, daemon=True).start()
        self.after(3000, self._rafraichir_donnees)

    def _mettre_a_jour_ui(self, data):
        temp  = data.get("temperature")
        hum   = data.get("humidite_air")
        sol   = data.get("humidite_sol")
        pluie = data.get("pluie", False)

        # Cartes capteurs
        if temp  is not None:
            self._update_card("temp",  temp,  "°C",  0, 50)
        if hum   is not None:
            self._update_card("hum",   hum,   "%",   0, 100)
        if sol   is not None:
            self._update_card("sol",   sol,   "%",   0, 100)

        pluie_lbl, pluie_bar, _, _ = self._cards_widgets["pluie"]
        pluie_lbl.configure(text="Oui 🌧️" if pluie else "Non ☀️",
                            fg=C["danger"] if pluie else C["accent"])

        # Statuts
        if temp is not None:
            seuil_t = self.plante_active["temp_max"] if self.plante_active else 30
            ok_t    = temp <= seuil_t
            self._status_widgets["temp_status"].configure(
                text=f"{temp}°C {'✓' if ok_t else '⚠'}",
                fg=C["accent"] if ok_t else C["danger"])

        if sol is not None:
            seuil_s = self.plante_active["eau_min"] if self.plante_active else 30
            ok_s    = sol >= seuil_s
            self._status_widgets["sol_status"].configure(
                text=f"{sol}% {'✓' if ok_s else '⚠'}",
                fg=C["accent"] if ok_s else C["warning"])

        self._status_widgets["pompe_status"].configure(
            text="ON ✓" if data.get("pompe") else "OFF",
            fg=C["accent"] if data.get("pompe") else C["text_muted"])
        self._status_widgets["ventilo_status"].configure(
            text="ON ✓" if data.get("ventilateur") else "OFF",
            fg=C["accent"] if data.get("ventilateur") else C["text_muted"])
        self._status_widgets["pluie_status"].configure(
            text="Pluie 🌧️" if pluie else "Sec ☀️",
            fg=C["info"] if pluie else C["text_muted"])

        # Plante active info
        if self.plante_active:
            self.lbl_plante_nom.configure(text=self.plante_active["nom"])
            self.lbl_plante_seuils.configure(
                text=f"Temp max : {self.plante_active['temp_max']}°C  |  "
                     f"Sol min : {self.plante_active['eau_min']}%")
        else:
            self.lbl_plante_nom.configure(text="Aucune plante sélectionnée")
            self.lbl_plante_seuils.configure(text="")

        # Sauvegarde MariaDB
        self._sauvegarder_capteurs(temp, hum, sol, pluie)

        # Logique automatique basée sur les seuils de la plante
        self._logique_automatique(temp, sol)

    def _update_card(self, key, val, unit, vmin, vmax):
        lbl, bar, _, color = self._cards_widgets[key]
        lbl.configure(text=f"{val} {unit}")
        ratio = max(0.0, min(1.0, (val - vmin) / (vmax - vmin)))
        bar.place(x=0, y=0, relwidth=ratio)

    # ------------------------------------------------------------------ #
    #  LOGIQUE AUTOMATIQUE BASÉE SUR LES SEUILS DE LA PLANTE              #
    # ------------------------------------------------------------------ #
    def _logique_automatique(self, temp, sol):
        """Affiche dans le log les alertes selon les seuils de la plante active.
           Le vrai contrôle matériel est fait par le Raspberry Pi."""
        if not self.plante_active:
            return

        if sol is not None:
            if sol < self.plante_active["eau_min"] and not self.pompe_on:
                self._log("WARN",
                          f"Sol sec ({sol}% < {self.plante_active['eau_min']}%). "
                          f"Pompe activée automatiquement.")
                self.pompe_on = True
                self.toggle_pompe.set_state(True)
                threading.Thread(
                    target=lambda: db.child("commandes").child(self.uid).update({"pompe": True}),
                    daemon=True).start()

            elif sol >= self.plante_active["eau_min"] + 10 and self.pompe_on:
                self._log("OK",
                          f"Humidité sol OK ({sol}%). Pompe arrêtée.")
                self.pompe_on = False
                self.toggle_pompe.set_state(False)
                threading.Thread(
                    target=lambda: db.child("commandes").child(self.uid).update({"pompe": False}),
                    daemon=True).start()

        if temp is not None:
            if temp > self.plante_active["temp_max"] and not self.ventilo_on:
                self._log("WARN",
                          f"Surchauffe ({temp}°C > {self.plante_active['temp_max']}°C). "
                          f"Ventilateur activé automatiquement.")
                self.ventilo_on = True
                self.toggle_ventilo.set_state(True)
                threading.Thread(
                    target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": True}),
                    daemon=True).start()

            elif temp <= self.plante_active["temp_max"] - 2 and self.ventilo_on:
                self._log("OK",
                          f"Température stabilisée ({temp}°C). Ventilateur arrêté.")
                self.ventilo_on = False
                self.toggle_ventilo.set_state(False)
                threading.Thread(
                    target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": False}),
                    daemon=True).start()

    # ------------------------------------------------------------------ #
    #  SAUVEGARDE MARIADB                                                  #
    # ------------------------------------------------------------------ #
    def _sauvegarder_capteurs(self, temp, hum, sol, pluie):
        def _save():
            try:
                conn = get_db(); cur = conn.cursor()
                cur.execute(
                    "INSERT INTO capteurs (uid,temperature,humidite_air,humidite_sol,pluie) "
                    "VALUES (%s,%s,%s,%s,%s)",
                    (self.uid, temp, hum, sol, pluie))
                conn.commit(); cur.close(); conn.close()
            except Exception as e:
                self._log("ERR", f"Erreur MariaDB : {e}")
        threading.Thread(target=_save, daemon=True).start()

    # ------------------------------------------------------------------ #
    #  HISTORIQUE                                                          #
    # ------------------------------------------------------------------ #
    def _charger_historique_stats(self):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute(
                "SELECT timestamp, temperature, humidite_air, humidite_sol, pluie "
                "FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 5",
                (self.uid,))
            rows = cur.fetchall()
            for item in self.table_stats.get_children():
                self.table_stats.delete(item)
            for index, r in enumerate(rows):
                tag      = "pair" if index % 2 == 0 else "impair"
                date_str = r[0].strftime("%d/%m/%Y %H:%M:%S") if r[0] else "--"
                pluie_str = "Oui 🌧️" if r[4] else "Non ☀️"
                self.table_stats.insert("", "end",
                    values=(date_str, f"{r[1]} °C", f"{r[2]} %",
                            f"{r[3]} %", pluie_str),
                    tags=(tag,))
            cur.close(); conn.close()
        except:
            pass
        self.after(10000, self._charger_historique_stats)

    # ------------------------------------------------------------------ #
    #  RENDU LISTE PLANTES                                                 #
    # ------------------------------------------------------------------ #
    def _render_plantes(self):
        for w in self.frame_plantes.winfo_children():
            w.destroy()

        if not self.plantes:
            tk.Label(self.frame_plantes,
                     text="Aucune plante configurée.",
                     font=("Segoe UI", 9, "italic"),
                     bg=C["bg_card"], fg=C["text_muted"]).pack(pady=10)
            return

        for p in self.plantes:
            is_active = (self.plante_active and
                         p["nom"] == self.plante_active["nom"])
            bg_item   = C["bg_input"] if is_active else C["bg_card"]

            item = tk.Frame(self.frame_plantes, bg=bg_item,
                            highlightthickness=1,
                            highlightbackground=C["accent"] if is_active else C["border"],
                            padx=12, pady=10)
            item.pack(fill="x", pady=4)

            tk.Label(item, text=f"🌱 {p['nom']}",
                     font=("Segoe UI", 10, "bold"),
                     bg=bg_item, fg=C["text_main"]).pack(side="left")

            if is_active:
                tk.Label(item, text="[ ACTIF ]",
                         font=("Segoe UI", 8, "bold"),
                         bg=bg_item, fg=C["accent"]).pack(side="left", padx=15)

            badge_box = tk.Frame(item, bg=bg_item)
            badge_box.pack(side="right")

            for txt, c in [(f"MAX T°: {p['temp_max']}°C", C["info"]),
                           (f"MIN SOL: {p['eau_min']}%",  C["warning"])]:
                b = tk.Frame(badge_box, bg=C["bg_main"], padx=8, pady=4,
                             highlightthickness=1,
                             highlightbackground=C["border"])
                b.pack(side="left", padx=5)
                tk.Label(b, text=txt, font=("Segoe UI", 8),
                         bg=C["bg_main"], fg=C["text_main"]).pack()

            if not is_active:
                b_sel = tk.Button(badge_box, text="SUIVRE",
                                  command=lambda pl=p: self._select_plante(pl))
                style_btn(b_sel, bg=C["border"], fg=C["text_main"])
                b_sel.pack(side="left", padx=10)

            b_del = tk.Button(badge_box, text="X",
                              command=lambda pl=p: self._suppr_plante(pl))
            style_btn(b_del, bg=C["danger"], fg=C["text_main"])
            b_del.pack(side="left", padx=5)

    # ------------------------------------------------------------------ #
    #  SÉLECTION PLANTE                                                    #
    # ------------------------------------------------------------------ #
    def _select_plante(self, p):
        self.plante_active = p
        self._render_plantes()
        self._log("INFO", f"Plante sélectionnée : [{p['nom'].upper()}]")
        self._log("INFO",
                  f"Seuils appliqués — Temp max: {p['temp_max']}°C | "
                  f"Sol min: {p['eau_min']}%")

        # Publie les nouveaux seuils sur Firebase → Raspberry Pi les lit
        self._publier_config_plante(p)

        # Met à jour l'affichage de la plante active
        self.lbl_plante_nom.configure(text=p["nom"])
        self.lbl_plante_seuils.configure(
            text=f"Temp max : {p['temp_max']}°C  |  Sol min : {p['eau_min']}%")

    # ------------------------------------------------------------------ #
    #  SUPPRESSION PLANTE                                                  #
    # ------------------------------------------------------------------ #
    def _suppr_plante(self, p):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("DELETE FROM plantes WHERE uid=%s AND nom=%s",
                        (self.uid, p["nom"]))
            conn.commit(); cur.close(); conn.close()
            self.plantes = [x for x in self.plantes if x["nom"] != p["nom"]]
            if self.plante_active and self.plante_active["nom"] == p["nom"]:
                self.plante_active = self.plantes[0] if self.plantes else None
                if self.plante_active:
                    self._publier_config_plante(self.plante_active)
            self._render_plantes()
            self._log("WARN", f"Plante supprimée : {p['nom']}")
        except Exception as e:
            self._log("ERR", f"Erreur suppression : {e}")

    # ------------------------------------------------------------------ #
    #  POPUP AJOUT PLANTE                                                  #
    # ------------------------------------------------------------------ #
    def _popup_ajout_plante(self):
        pop = tk.Toplevel(self)
        pop.title("Ajouter une plante")
        pop.configure(bg=C["bg_card"])
        pop.geometry("380x420")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(pop, text="🌱 Nouvelle Plante",
                 font=("Segoe UI", 14, "bold"),
                 bg=C["bg_card"], fg=C["accent"]).pack(pady=(20, 10))

        f_fields = tk.Frame(pop, bg=C["bg_card"], padx=30)
        f_fields.pack(fill="x")

        entries = {}
        fields  = [
            ("Nom de la plante",          "nom",   "Ex: Tomate"),
            ("Température max (°C)",       "t_max", "30"),
            ("Humidité sol minimale (%)",  "e_min", "40"),
        ]
        for label, key, default in fields:
            tk.Label(f_fields, text=label, font=("Segoe UI", 8, "bold"),
                     bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w", pady=(5, 0))
            e = tk.Entry(f_fields)
            style_entry(e)
            e.insert(0, default)
            e.pack(fill="x", pady=(4, 12), ipady=6)
            entries[key] = e

        lbl_err = tk.Label(f_fields, text="", font=("Segoe UI", 9),
                           bg=C["bg_card"], fg=C["danger"])
        lbl_err.pack()

        def valider():
            nom = entries["nom"].get().strip()
            if not nom:
                lbl_err.configure(text="Nom requis."); return
            try:
                tm = float(entries["t_max"].get())
                em = float(entries["e_min"].get())
            except:
                lbl_err.configure(text="Valeurs numériques incorrectes."); return

            try:
                conn = get_db(); cur = conn.cursor()
                cur.execute(
                    "INSERT INTO plantes (uid,nom,temp_max,humidite_min,eau_min) "
                    "VALUES (%s,%s,%s,%s,%s)",
                    (self.uid, nom, tm, 0.0, em))
                conn.commit(); cur.close(); conn.close()

                nouvelle_plante = {"nom": nom, "temp_max": tm,
                                   "humidite_min": 0.0, "eau_min": em}
                self.plantes.append(nouvelle_plante)

                # Si c'est la première plante, elle devient active automatiquement
                if not self.plante_active:
                    self.plante_active = nouvelle_plante

                self._render_plantes()
                self._log("OK", f"Plante enregistrée : {nom}")
                self._log("INFO",
                          f"Seuils — Temp max: {tm}°C | Sol min: {em}%")

                # Publie les seuils de la plante active sur Firebase
                self._publier_config_plante(self.plante_active)

                # Met à jour l'affichage
                self.lbl_plante_nom.configure(text=self.plante_active["nom"])
                self.lbl_plante_seuils.configure(
                    text=f"Temp max : {self.plante_active['temp_max']}°C  |  "
                         f"Sol min : {self.plante_active['eau_min']}%")

                pop.destroy()
            except Exception as ex:
                lbl_err.configure(text=f"Erreur DB : {ex}")

        btn_save = tk.Button(f_fields, text="ENREGISTRER", command=valider)
        style_btn(btn_save)
        btn_save.pack(fill="x", ipady=6, pady=(10, 0))

    # ------------------------------------------------------------------ #
    #  CONTRÔLES MANUELS POMPE / VENTILO                                   #
    # ------------------------------------------------------------------ #
    def _api_pompe(self, state):
        self.pompe_on = state
        self._log("OK" if state else "WARN",
                  f"Manuel → Pompe : {'ON' if state else 'OFF'}")
        threading.Thread(
            target=lambda: db.child("commandes").child(self.uid).update({"pompe": state}),
            daemon=True).start()

    def _api_ventilo(self, state):
        self.ventilo_on = state
        self._log("OK" if state else "WARN",
                  f"Manuel → Ventilation : {'ON' if state else 'OFF'}")
        threading.Thread(
            target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": state}),
            daemon=True).start()

    # ------------------------------------------------------------------ #
    #  CONSOLE LOG                                                         #
    # ------------------------------------------------------------------ #
    def _log(self, level, msg):
        self.after(0, self._log_ui, level, msg)

    def _log_ui(self, level, msg):
        self.console.configure(state="normal")
        ts = time.strftime("%H:%M:%S")
        self.console.insert("end", f"[{ts}] ", "TEXT_MUTED")
        self.console.insert("end", f"[{level}] ", level)
        self.console.insert("end", f"{msg}\n")
        self.console.configure(state="disabled")
        self.console.see("end")

    def _clear_console(self):
        self.console.configure(state="normal")
        self.console.delete("1.0", "end")
        self.console.configure(state="disabled")

# --- APPLICATION MASTER ---
class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("Serre Connected Management System")
        self.fen.geometry("1080x840")
        self.fen.configure(bg=C["bg_main"])
        self.fen.resizable(False, False)
        init_db()
        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page: self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page: self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def run(self):
        self.fen.mainloop()

if __name__ == "__main__":
    App().run()
