    def _charger_plantes(self):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("SELECT nom, temp_max, humidite_min, eau_min FROM plantes WHERE uid=%s",
                        (self.uid,))
            rows = cur.fetchall()
            cur.close(); conn.close()
            self.plantes = [{"nom": r[0], "temp_max": r[1],
                             "humidite_min": r[2], "eau_min": r[3]} for r in rows]
            if self.plantes and not self.plante_active:
                self.plante_active = self.plantes[0]
                self._publier_config_plante(self.plante_active)
        except Exception as e:
            print(f"[DB] Erreur chargement plantes: {e}")

    # ------------------------------------------------------------------ #
    #  PUBLICATION DES SEUILS SUR FIREBASE                                 #
    # ------------------------------------------------------------------ #
    def _publier_config_plante(self, plante):
        """Envoie les seuils de la plante active sur Firebase
           pour que le Raspberry Pi les applique."""
        def _push():
            try:
                db.child("config_plante").child(self.uid).set({
                    "nom":      plante["nom"],
                    "temp_max": plante["temp_max"],
                    "eau_min":  plante["eau_min"]
                })
                print(f"[Firebase] Seuils publiés — "
                      f"TempMax={plante['temp_max']}°C "
                      f"SolMin={plante['eau_min']}%")
            except Exception as e:
                print(f"[Firebase] Erreur publication seuils: {e}")
        threading.Thread(target=_push, daemon=True).start()

