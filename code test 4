    # ─── CAPTEURS ──────────────────────────────────────────────────────────────
    def _rafraichir_donnees(self):
        """Lit les capteurs depuis MariaDB"""
        def _fetch():
            try:
                conn = get_db()
                cur = conn.cursor()
                
                # Dernière lecture pour cette plante
                cur.execute(
                    "SELECT temperature, humidite_air, humidite_sol, pluie, timestamp "
                    "FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 1",
                    (self.uid,)
                )
                row = cur.fetchone()
                
                if row:
                    temp, hum, sol, pluie, ts = row
                    self.after(0, self._afficher_capteurs, temp, hum, sol, pluie)
                
                # Historique (dernières 10 lignes)
                cur.execute(
                    "SELECT temperature, humidite_air, humidite_sol, pluie, timestamp "
                    "FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 10",
                    (self.uid,)
                )
                historique = cur.fetchall()
                self.after(0, self._afficher_historique, historique)
                
                cur.close()
                conn.close()
                self._log("OK", f"T:{temp:.1f}°C | H:{hum:.0f}% | Sol:{sol:.0f}%")
                
            except Exception as e:
                self._log("ERR", f"MariaDB: {str(e)[:50]}")
        
        threading.Thread(target=_fetch, daemon=True).start()
        self.after(2000, self._rafraichir_donnees)
    
    def _afficher_capteurs(self, temp, hum, sol, pluie):
        self.temp = temp
        self.hum = hum
        self.sol = sol
        self.pluie = pluie
        
        self.lbl_temp.configure(text=f"{temp:.1f} °C")
        self.lbl_hum.configure(text=f"{hum:.0f} %")
        self.lbl_sol.configure(text=f"{sol:.0f} %")
        
        pluie_text = "OUI 🌧️" if pluie else "NON ☀️"
        pluie_color = C["danger"] if pluie else C["accent"]
        self.lbl_pluie.configure(text=pluie_text, fg=pluie_color)
    
    def _afficher_historique(self, historique):
        """Affiche l'historique dans la table"""
        # Nettoyer
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        # Ajouter les données
        for temp, hum, sol, pluie, ts in reversed(historique):
            date_str = ts.strftime("%d/%m %H:%M") if ts else "--"
            pluie_str = "OUI" if pluie else "NON"
            self.tree.insert("", "end", values=(
                date_str,
                f"{temp:.1f}°C" if temp else "--",
                f"{hum:.0f}%" if hum else "--",
                f"{sol:.0f}%" if sol else "--",
                pluie_str
            ))
    
    # ─── COMMANDES ────────────────────────────────────────────────────────────
    def _changer_mode(self):
        mode_auto = self.var_mode.get()
        try:
            db.child("commandes").child(self.uid).update({"mode_auto": mode_auto})
            mode_text = "AUTO" if mode_auto else "MANUEL"
            self._log("OK", f"Mode: {mode_text}")
        except Exception as e:
            self._log("ERR", f"Erreur mode: {e}")
    
    def _api_pompe(self):
        state = self.var_pompe.get()
        threading.Thread(
            target=lambda: db.child("commandes").child(self.uid).update({"pompe": state}),
            daemon=True
        ).start()
        
        text = "ON ✅" if state else "OFF ❌"
        color = C["accent"] if state else C["danger"]
        self.lbl_pompe.configure(text=text, fg=color)
        self._log("OK", f"Pompe: {text}")
    
    def _api_ventilo(self):
        state = self.var_ventilo.get()
        threading.Thread(
            target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": state}),
            daemon=True
        ).start()
        
        text = "ON ✅" if state else "OFF ❌"
        color = C["accent"] if state else C["danger"]
        self.lbl_ventilo.configure(text=text, fg=color)
        self._log("OK", f"Ventilo: {text}")
    
    # ─── Utils ────────────────────────────────────────────────────────────────
    def _log(self, status, message):
        emoji = "✓" if status == "OK" else "✗" if status == "ERR" else "ℹ"
        self.lbl_status.configure(text=f"{emoji} {message}")

# ─── Application principale ───────────────────────────────────────────────────
class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("Serre Connected")
        self.fen.geometry("1200x800")
        self.fen.configure(bg=C["bg_main"])
        self.fen.resizable(False, False)
        
        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page:
            self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page:
            self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def run(self):
        self.fen.mainloop()

if __name__ == "__main__":
    App().run()
