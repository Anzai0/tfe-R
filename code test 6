                tk.Label(sub, text="MONITORED", font=("Segoe UI", 8, "bold"), bg=p_box.cget("bg"), fg=C["accent_green"]).pack(side="left")

            b_rm = tk.Button(sub, text="DELETE", font=("Segoe UI", 8, "bold"), bg=C["bg_main"], fg=C["accent_red"], relief="flat", bd=0, cursor="hand2", command=lambda pl=p: self._delete_plante(pl))
            b_rm.pack(side="right")

    def _select_plante(self, p):
        self.plante_active = p
        self._render_plantes_layout()
        self._write_log("INF", f"Régulation basculée sur la cible : {p['nom'].upper()}")

    def _delete_plante(self, p):
        if not messagebox.askyesno("Confirm", "Effacer définitivement ce profil végétal ?"): return
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("DELETE FROM plantes WHERE uid=%s AND nom=%s", (self.uid, p["nom"]))
            conn.commit(); cur.close(); conn.close()
            self.plantes = [x for x in self.plantes if x["nom"] != p["nom"]]
            if self.plante_active and self.plante_active["nom"] == p["nom"]:
                self.plante_active = self.plantes[0] if self.plantes else None
            self._render_plantes_layout()
            self._write_log("WRN", f"Profil supprimé de l'index : {p['nom']}")
        except: pass

    def _popup_nouvelle_plante(self):
        pop = tk.Toplevel(self)
        pop.configure(bg=C["bg_main"])
        pop.geometry("350x360")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(pop, text="NEW VEGETAL EQUALIZER", font=("Segoe UI", 10, "bold"), bg=C["bg_main"], fg=C["text_main"]).pack(pady=15)
        f = tk.Frame(pop, bg=C["bg_card"], padx=20, pady=20, highlightthickness=1, highlightbackground=C["border"])
        f.pack(fill="both", expand=True, padx=20, pady=(0, 20))

        inputs = [("NOM DU VEGETAL", "nom", ""), ("SEUIL TEMP MAX (°C)", "t_max", "30"), ("SEUIL HYDRIQUE MIN (%)", "e_min", "40")]
        dict_e = {}
        for l, k, def_val in inputs:
            tk.Label(f, text=l, font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
            e = tk.Entry(f); ui_entry(e); e.insert(0, def_val); e.pack(fill="x", pady=(4, 10), ipady=4)
            dict_e[k] = e

        def save():
            n = dict_e["nom"].get().strip()
            if not n: return
            try:
                tm, em = float(dict_e["t_max"].get()), float(dict_e["e_min"].get())
                conn = get_db(); cur = conn.cursor()
                cur.execute("INSERT INTO plantes (uid,nom,temp_max,humidite_min,eau_min) VALUES (%s,%s,%s,%s,%s)", (self.uid, n, tm, 0.0, em))
                conn.commit(); cur.close(); conn.close()
                self.plantes.append({"nom": n, "temp_max": tm, "humidite_min": 0.0, "eau_min": em})
                if not self.plante_active: self.plante_active = self.plantes[0]
                self._render_plantes_layout()
                pop.destroy()
            except: pass

        btn = tk.Button(f, text="COMMIT INITIALIZATION", command=save); ui_btn(btn); btn.pack(fill="x", pady=(10, 0), ipady=5)

    def _api_pompe(self, state, manuel=False):
        self.pompe_on = state
        self._write_log("OK" if state else "WRN", f"Statut Relais Pompe mis à jour -> {'ACTIF' if state else 'INACTIF'}")
        if manuel:
            threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"pompe": state}), daemon=True).start()

    def _api_ventilo(self, state, manuel=False):
        self.ventilo_on = state
        self._write_log("OK" if state else "WRN", f"Statut Extraction Air mis à jour -> {'ACTIF' if state else 'INACTIF'}")
        if manuel:
            threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": state}), daemon=True).start()

    def _boucle_telemetrie(self):
        def loop():
            try:
                snapshot = db.child("capteurs").child(self.uid).get().val()
                if snapshot: self.after(0, self._sync_telemetrie, snapshot)
            except: pass
            self.after(5000, self._boucle_telemetrie)
        threading.Thread(target=loop, daemon=True).start()

    def _sync_telemetrie(self, d):
        t = d.get("temperature", 0.0)
        h = d.get("humidite_air", 0.0)
        s = d.get("humidite_sol", 0.0)
        p = d.get("pluie", False)

        self.g_temp.set_value(t)
        self.g_hum.set_value(h)
        self.g_sol.set_value(s)
        
        is_raining = not p
        self.g_pluie.set_status(is_raining)

        self._write_log("INF", f"Synchronisation : Temp {t}°C | Sol {s}% | Pluie: {'Oui' if is_raining else 'Non'}")

        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("INSERT INTO capteurs (uid,temperature,humidite_air,humidite_sol,pluie) VALUES (%s,%s,%s,%s,%s)", (self.uid, t, h, s, p))
            conn.commit(); cur.close(); conn.close()
        except: pass

        if self.plante_active:
            if s < self.plante_active["eau_min"]:
                if not self.pompe_on:
                    self.sw_pompe.set_state(True)
                    self._api_pompe(True, manuel=True)
                    self._write_log("WRN", f"Hydrométrie critique ({s}% < {self.plante_active['eau_min']}%). Injection d'eau requise.")
            elif s >= self.plante_active["eau_min"] + 10:
                if self.pompe_on:
                    self.sw_pompe.set_state(False)
                    self._api_pompe(False, manuel=True)

            if t > self.plante_active["temp_max"]:
                if not self.ventilo_on:
                    self.sw_ventilo.set_state(True)
                    self._api_ventilo(True, manuel=True)
                    self._write_log("ERR", f"Surchauffe thermique ({t}°C > {self.plante_active['temp_max']}°C). Déclenchement extracteur d'air.")
            elif t <= self.plante_active["temp_max"] - 2:
                if self.ventilo_on:
                    self.sw_ventilo.set_state(False)
                    self._api_ventilo(False, manuel=True)

    def _boucle_stats(self):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("SELECT timestamp, temperature, humidite_air, humidite_sol, pluie FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 5", (self.uid,))
            rows = cur.fetchall()
            for x in self.tree.get_children(): self.tree.delete(x)
            for r in rows:
                t_str = r[0].strftime("%d/%m %H:%M:%S") if r[0] else "Unknown"
                self.tree.insert("", "end", values=(t_str, f"{r[1]}°C", f"{r[2]}%", f"{r[3]}%", "OUI" if not r[4] else "NON"))
            cur.close(); conn.close()
        except: pass
        self.after(6000, self._boucle_stats)

    def _write_log(self, tag, msg):
        self.after(0, self._append_terminal, tag, msg)

    def _append_terminal(self, tag, msg):
        self.terminal.configure(state="normal")
        h = time.strftime("%H:%M:%S")
        self.terminal.insert("end", f"[{h}] ", "MUT")
        self.terminal.insert("end", f"[{tag}] ", tag)
        self.terminal.insert("end", f"{msg}\n")
        self.terminal.configure(state="disabled")
        self.terminal.see("end")

    def _flush_terminal(self):
        self.terminal.configure(state="normal")
        self.terminal.delete("1.0", "end")
        self.terminal.configure(state="disabled")

