class PageConnexion(tk.Frame):
    def __init__(self, parent, on_conn):
        super().__init__(parent, bg=C["bg_main"])
        self.on_conn = on_conn
        self.mode = "connexion"
        self._build()

    def _build(self):
        f = tk.Frame(self, bg=C["bg_card"], padx=40, pady=40, highlightthickness=1, highlightbackground=C["border"])
        f.place(relx=0.5, rely=0.5, anchor="center", width=420)

        self.title = tk.Label(f, text="CORE ACCESS", font=("Segoe UI", 20, "bold"), bg=C["bg_card"], fg=C["text_main"])
        self.title.pack(anchor="w", pady=(0, 25))

        tk.Label(f, text="OPERATOR EMAIL", font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_email = tk.Entry(f)
        ui_entry(self.e_email)
        self.e_email.pack(fill="x", pady=(5, 15), ipady=6)

        tk.Label(f, text="ACCESS KEY / PASSWORD", font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_mdp = tk.Entry(f, show="*")
        ui_entry(self.e_mdp)
        self.e_mdp.pack(fill="x", pady=(5, 25), ipady=6)

        self.btn_sub = tk.Button(f, text="CONNECT SYSTEM", command=self._action)
        ui_btn(self.btn_sub)
        self.btn_sub.pack(fill="x", ipady=8, pady=(0, 15))

        self.btn_sw = tk.Button(f, text="Create an operator account", bg=C["bg_card"], fg=C["text_muted"], bd=0, font=("Segoe UI", 9, "underline"), cursor="hand2", command=self._toggle)
        self.btn_sw.pack()

        self.lbl_err = tk.Label(f, text="", font=("Segoe UI", 9), bg=C["bg_card"], fg=C["accent_red"])
        self.lbl_err.pack(pady=(10, 0))

    def _toggle(self):
        if self.mode == "connexion":
            self.mode = "inscription"
            self.title.configure(text="REGISTRATION")
            self.btn_sw.configure(text="Back to log-in")
        else:
            self.mode = "connexion"
            self.title.configure(text="CORE ACCESS")
            self.btn_sw.configure(text="Create an operator account")

    def _action(self):
        e, m = self.e_email.get().strip(), self.e_mdp.get().strip()
        if not e or not m: return
        def run():
            try:
                u = auth.sign_in_with_email_and_password(e, m) if self.mode == "connexion" else auth.create_user_with_email_and_password(e, m)
                self.after(0, lambda: self.on_conn(u["localId"], e))
            except:
                self.after(0, lambda: self.lbl_err.configure(text="ERROR: Access Denied."))
        threading.Thread(target=run, daemon=True).start()


