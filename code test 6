# --- COMPOSANT : BOUTON SWITCH FUTURISTE ---
class CustomToggle(tk.Canvas):
    def __init__(self, parent, command=None, width=60, height=22):
        super().__init__(parent, width=width, height=height, bg=C["bg_card"], bd=0, highlightthickness=0, cursor="hand2")
        self.command = command
        self.state = False
        self.width = width
        self.height = height
        self.bind("<Button-1>", self._toggle)
        self._draw()

    def _draw(self):
        self.delete("all")
        bg_col = C["accent_cyan"] if self.state else C["bg_input"]
        self.create_rectangle(0, 0, self.width, self.height, fill=bg_col, outline=C["border"])
        
        # Curseur carré/rectangulaire
        x_pos = (self.width - 18) if self.state else 2
        self.create_rectangle(x_pos, 2, x_pos + 16, self.height - 2, fill="#FFFFFF", outline="")

    def _toggle(self, event):
        self.state = not self.state
        self._draw()
        if self.command:
            self.command(self.state, manuel=True)

    def set_state(self, state):
        if self.state != state:
            self.state = state
            self._draw()

