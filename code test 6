# --- NOUVEAU COMPOSANT : BARRE DE PROGRESSION EN LIGNE DESIGN ---
class LinearTechGauge(tk.Frame):
    def __init__(self, parent, label="CAPTEUR", unit="", max_val=100, color="#06B6D4"):
        super().__init__(parent, bg=C["bg_card"], bd=0)
        self.label = label
        self.unit = unit
        self.max_val = max_val
        self.color = color
        self.value = 0.0
        
        # Textes de données
        self.lbl_title = tk.Label(self, text=self.label, font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"])
        self.lbl_title.pack(anchor="w")
        
        self.lbl_val = tk.Label(self, text=f"0.0 {self.unit}", font=("Consolas", 18, "bold"), bg=C["bg_card"], fg=C["text_main"])
        self.lbl_val.pack(anchor="w", pady=(2, 5))
        
        # Mini canvas pour la jauge rectiligne épurée
        self.canvas = tk.Canvas(self, height=8, bg=C["bg_input"], bd=0, highlightthickness=0)
        self.canvas.pack(fill="x", pady=2)
        
    def set_value(self, val):
        self.value = val
        self.lbl_val.configure(text=f"{val} {self.unit}")
        self.canvas.delete("all")
        
        # Calcul de la largeur
        self.update_idletasks()
        w = self.canvas.winfo_width()
        pct = max(0.0, min(1.0, self.value / self.max_val)) if self.max_val > 0 else 0
        
        # Dessin de la barre remplie avec angles droits nets
        if w > 1:
            self.canvas.create_rectangle(0, 0, int(w * pct), 8, fill=self.color, outline="")

