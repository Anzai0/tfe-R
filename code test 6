class App:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Nexus Ecosystem Core")
        # FIX : Format géométrie nettoyé de tout caractère parasite
        self.root.geometry("1260x860")
        self.root.configure(bg=C["bg_main"])
        self.root.resizable(False, False)
        init_db()
        self.current_frame = None
        self._goto_connexion()

    def _goto_connexion(self):
        if self.current_frame: self.current_frame.destroy()
        self.current_frame = PageConnexion(self.root, self._goto_dashboard)
        self.current_frame.pack(fill="both", expand=True)

    def _goto_dashboard(self, uid, email):
        if self.current_frame: self.current_frame.destroy()
        self.current_frame = PageDashboard(self.root, uid, email, self._goto_connexion)
        self.current_frame.pack(fill="both", expand=True)

    def run(self):
        self.root.mainloop()

if __name__ == "__main__":
    App().run()
