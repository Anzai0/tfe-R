class PageConnexion(tk.Frame):
    def __init__(self, parent, on_conn):
        super().__init__(parent, bg=C["bg_main"])
        self.on_conn = on_conn
        self.mode = "connexion"
        self._build()

    def _build(self):
        container = tk.Frame(self, bg=C["bg_card"], padx=45, pady=45, highlightthickness=1, highlightbackground=C["border"])
        container.place(relx=0.5, rely=0.5, anchor="center", width=440)

        self.lbl_title = tk.Label(container, text="Authentification", font=("Segoe UI", 22, "bold"), bg=C["bg_card"], fg=C["text_main"])
        self.lbl_title.pack(anchor="w", pady=(0, 4))
        
        self.lbl_subtitle = tk.Label(container, text="ENTREPRISE HUB CONSOLE", font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["brand"])
        self.lbl_subtitle.pack(anchor="w", pady=(0, 30))

        tk.Label(container, text="IDENTIFIANT EMAIL", font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_email = tk.Entry(container)
        style_entry(self.e_email)
        self.e_email.pack(fill="x", pady=(5, 18), ipady=8)

        tk.Label(container, text="MOT DE PASSE", font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_mdp = tk.Entry(container, show="*")
        style_entry(self.e_mdp)
        self.e_mdp.pack(fill="x", pady=(5, 25), ipady=8)

        self.btn_submit = tk.Button(container, text="Continuer", command=self._action)
        style_btn(self.btn_submit)
        self.btn_submit.pack(fill="x", ipady=8, pady=(0, 20))

        self.btn_switch = tk.Button(container, text="Créer un compte professionnel", bg=C["bg_card"], fg=C["text_muted"], bd=0, font=("Segoe UI", 9, "underline"), cursor="hand2")
        self.btn_switch.configure(command=self._toggle_mode)
        self.btn_switch.pack()

        self.lbl_msg = tk.Label(container, text="", font=("Segoe UI", 9), bg=C["bg_card"], fg=C["danger"])
        self.lbl_msg.pack(pady=(10, 0))

    def _toggle_mode(self):
        if self.mode == "connexion":
            self.mode = "inscription"
            self.lbl_title.configure(text="Nouvel Utilisateur")
            self.btn_switch.configure(text="J'ai déjà un compte")
        else:
            self.mode = "connexion"
            self.lbl_title.configure(text="Authentification")
            self.btn_switch.configure(text="Créer un compte professionnel")

    def _action(self):
        email = self.e_email.get().strip()
        mdp = self.e_mdp.get().strip()
        if not email or not mdp: return
        
        def tache():
            try:
                user = auth.sign_in_with_email_and_password(email, mdp) if self.mode == "connexion" else auth.create_user_with_email_and_password(email, mdp)
                self.after(0, lambda: self.on_conn(user["localId"], email))
            except Exception as e:
                self.after(0, lambda: self.lbl_msg.configure(text="Échec de l'opération."))
        threading.Thread(target=tache, daemon=True).start()


