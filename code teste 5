    def _charger_historique_stats(self):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("SELECT timestamp, temperature, humidite_air, humidite_sol, pluie FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 4", (self.uid,))
            rows = cur.fetchall()
            for item in self.table_stats.get_children(): self.table_stats.delete(item)
            for r in rows:
                d_str = r[0].strftime("%d/%m %H:%M") if r[0] else "--"
                self.table_stats.insert("", "end", values=(d_str, f"{r[1]}°C", f"{r[2]}%", f"{r[3]}%", "Oui" if r[4] else "Non"))
            cur.close(); conn.close()
        except: pass
        self.after(8000, self._charger_historique_stats)

    def _render_plantes(self):
        for w in self.plant_section.winfo_children(): w.destroy()
        tk.Label(self.plant_section, text=f"PROFILS ACTIFS ({len(self.plantes)}/3)", font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w", pady=(0, 10))

        if len(self.plantes) < 3:
            btn_add = tk.Button(self.plant_section, text="+ AJOUTER UN PROFIL", command=self._popup_plante)
            style_btn(btn_add, bg=C["brand"])
            btn_add.pack(fill="x", pady=(0, 10), ipady=5)

        for p in self.plantes:
            is_act = self.plante_active and self.plante_active["nom"] == p["nom"]
            box = tk.Frame(self.plant_section, bg=C["bg_input"] if is_act else C["bg_card"], highlightthickness=1, highlightbackground=C["brand"] if is_act else C["border"], padx=10, pady=8)
            box.pack(fill="x", pady=4)

            tk.Label(box, text=p["nom"].upper(), font=("Segoe UI", 9, "bold"), bg=box.cget("bg"), fg=C["text_main"]).pack(anchor="w")
            
            sub = tk.Frame(box, bg=box.cget("bg"))
            sub.pack(fill="x", pady=(5, 0))

            if not is_act:
                b_sel = tk.Button(sub, text="SUIVRE", command=lambda pl=p: self._select_plante(pl), font=("Segoe UI", 8, "bold"), bg=C["border"], fg=C["text_main"], relief="flat", bd=0, cursor="hand2")
                b_sel.pack(side="left", padx=(0, 5))
            else:
                tk.Label(sub, text="SURVEILLANCE EN COURS", font=("Segoe UI", 7, "bold"), bg=box.cget("bg"), fg=C["success"]).pack(side="left")

            b_del = tk.Button(sub, text="SUPPRIMER", command=lambda pl=p: self._suppr_plante(pl), font=("Segoe UI", 8, "bold"), bg=C["danger"], fg=C["text_main"], relief="flat", bd=0, cursor="hand2")
            b_del.pack(side="right")

    def _select_plante(self, p):
        self.plante_active = p
        self._render_plantes()
        self._log("INFO", f"Changement de consigne cible : {p['nom'].upper()}")

    def _suppr_plante(self, p):
        if not messagebox.askyesno("Confirmation", "Supprimer ce profil ?"): return
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("DELETE FROM plantes WHERE uid=%s AND nom=%s", (self.uid, p["nom"]))
            conn.commit(); cur.close(); conn.close()
            self.plantes = [x for x in self.plantes if x["nom"] != p["nom"]]
            if self.plante_active and self.plante_active["nom"] == p["nom"]:
                self.plante_active = self.plantes[0] if self.plantes else None
            self._render_plantes()
            self._log("WARN", f"Profil effacé : {p['nom']}")
        except: pass

    def _popup_plante(self):
        pop = tk.Toplevel(self)
        pop.configure(bg=C["bg_main"])
        pop.geometry("360x380")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(pop, text="NOUVEAU CONFIGURATEUR", font=("Segoe UI", 10, "bold"), bg=C["bg_main"], fg=C["text_main"]).pack(pady=20)
        f = tk.Frame(pop, bg=C["bg_card"], padx=20, pady=20, highlightthickness=1, highlightbackground=C["border"])
        f.pack(fill="both", expand=True, padx=20, pady=(0, 20))

        fields = [("NOM", "nom", ""), ("TEMP MAX (°C)", "t_max", "28"), ("SEUIL EAU SOL (%)", "e_min", "45")]
        entries = {}
        for lbl, key, d in fields:
            tk.Label(f, text=lbl, font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
            e = tk.Entry(f); style_entry(e); e.insert(0, d); e.pack(fill="x", pady=(4, 10), ipady=5)
            entries[key] = e

        def valider():
            n = entries["nom"].get().strip()
            if not n: return
            try:
                tm, em = float(entries["t_max"].get()), float(entries["e_min"].get())
                conn = get_db(); cur = conn.cursor()
                cur.execute("INSERT INTO plantes (uid,nom,temp_max,humidite_min,eau_min) VALUES (%s,%s,%s,%s,%s)", (self.uid, n, tm, 0.0, em))
                conn.commit(); cur.close(); conn.close()
                self.plantes.append({"nom": n, "temp_max": tm, "humidite_min": 0.0, "eau_min": em})
                if not self.plante_active: self.plante_active = self.plantes[0]
                self._render_plantes()
                pop.destroy()
            except: pass

        b = tk.Button(f, text="VALIDER PROFIL", command=valider); style_btn(b); b.pack(fill="x", pady=(10, 0), ipady=6)

    def _api_pompe(self, state):
        self.pompe_on = state
        self._log("OK" if state else "WARN", f"Relais Pompe -> {'ACTIF' if state else 'INACTIF'}")
        threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"pompe": state}), daemon=True).start()

    def _api_ventilo(self, state):
        self.ventilo_on = state
        self._log("OK" if state else "WARN", f"Relais Ventilateur -> {'ACTIF' if state else 'INACTIF'}")
        threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": state}), daemon=True).start()

    def _rafraichir_donnees(self):
        def tache():
            try:
                d = db.child("capteurs").child(self.uid).get().val()
                if d: self.after(0, self._process_telemetrie, d)
            except: pass
            self.after(5000, self._rafraichir_donnees)
        threading.Thread(target=tache, daemon=True).start()

    def _process_telemetrie(self, data):
        t = data.get("temperature", 0.0)
        h = data.get("humidite_air", 0.0)
        s = data.get("humidite_sol", 0.0)
        p = data.get("pluie", False)

        self.c_temp.set_value(t)
        self.c_hum.set_value(h)
        self.c_sol.set_value(s)

        self._log("INFO", f"Synchronisation : Temp {t}°C | Sol {s}%")

        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("INSERT INTO capteurs (uid,temperature,humidite_air,humidite_sol,pluie) VALUES (%s,%s,%s,%s,%s)", (self.uid, t, h, s, p))
            conn.commit(); cur.close(); conn.close()
        except: pass

        if self.plante_active:
            if s < self.plante_active["eau_min"] and not self.pompe_on:
                self.pompe_on = True; self.toggle_pompe.set_state(True)
                db.child("commandes").child(self.uid).update({"pompe": True})
            elif s >= self.plante_active["eau_min"] + 10 and self.pompe_on:
                self.pompe_on = False; self.toggle_pompe.set_state(False)
                db.child("commandes").child(self.uid).update({"pompe": False})

            if t > self.plante_active["temp_max"] and not self.ventilo_on:
                self.ventilo_on = True; self.toggle_ventilo.set_state(True)
                db.child("commandes").child(self.uid).update({"ventilateur": True})
            elif t <= self.plante_active["temp_max"] - 2 and self.ventilo_on:
                self.ventilo_on = False; self.toggle_ventilo.set_state(False)
                db.child("commandes").child(self.uid).update({"ventilateur": False})

    def _log(self, level, msg):
        self.after(0, self._log_ui, level, msg)

    def _log_ui(self, level, msg):
        self.console.configure(state="normal")
        ts = time.strftime("%H:%M:%S")
        self.console.insert("end", f"[{ts}] ", "MUTED")
        self.console.insert("end", f"[{level}] ", level)
        self.console.insert("end", f"{msg}\n")
        self.console.configure(state="disabled")
        self.console.see("end")

    def _clear_console(self):
        self.console.configure(state="normal")
        self.console.delete("1.0", "end")
        self.console.configure(state="disabled")

# --- APP MASTER ---
class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("EcoSphere OS")
        # CORRECTION : Remplacement du caractère invalide par un 'x' standard de géométrie Tkinter
        self.fen.geometry("1100x820")
        self.fen.configure(bg=C["bg_main"])
        self.fen.resizable(False, False)
        init_db()
        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page: self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page: self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def run(self):
        self.fen.mainloop()

if __name__ == "__main__":
    App().run()
