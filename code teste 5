    def _charger_historique_stats(self):
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("SELECT timestamp, temperature, humidite_air, humidite_sol, pluie FROM capteurs WHERE uid=%s ORDER BY id DESC LIMIT 4", (self.uid,))
            rows = cur.fetchall()
            for item in self.table_stats.get_children(): self.table_stats.delete(item)
            for r in rows:
                d_str = r[0].strftime("%d/%m/%Y %H:%M:%S") if r[0] else "--"
                self.table_stats.insert("", "end", values=(d_str, f"{r[1]} °C", f"{r[2]} %", f"{r[3]} %", "Oui ☀" if not r[4] else "Non 🌧"))
            cur.close(); conn.close()
        except: pass
        self.after(5000, self._charger_historique_stats)

