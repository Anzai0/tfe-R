# --- COMPOSANT : ANNEAU DE PROGRESSION CIRCULAIRE (STYLE SMART HOME) ---
class CircularProgress(tk.Canvas):
    def __init__(self, parent, label="Capteur", unit="", max_val=100, color="#3B82F6"):
        super().__init__(parent, width=130, height=130, bg=C["bg_card"], bd=0, highlightthickness=0)
        self.label = label
        self.unit = unit
        self.max_val = max_val
        self.color = color
        self.value = 0.0
        self._draw()

    def _draw(self):
        self.delete("all")
        # Anneau de fond (Gris)
        self.create_arc(15, 15, 115, 115, start=0, extent=359, outline="#334155", width=8, style="arc")
        
        # Calcul de l'angle selon la valeur
        extent_angle = -(self.value / self.max_val) * 360 if self.max_val > 0 else 0
        if extent_angle < -360: extent_angle = -360
        
        # Anneau actif
        if extent_angle != 0:
            self.create_arc(15, 15, 115, 115, start=90, extent=extent_angle, outline=self.color, width=8, style="arc")
        
        # Textes centraux
        self.create_text(65, 55, text=f"{self.value}{self.unit}", fill=C["text_main"], font=("Segoe UI", 16, "bold"))
        self.create_text(65, 80, text=self.label, fill=C["text_muted"], font=("Segoe UI", 9, "bold"))

    def set_value(self, val):
        self.value = val
        self._draw()

# --- COMPOSANT : TOGGLE SWITCH PREMIUM (STYLE iOS) ---
class IOSSwitch(tk.Canvas):
    def __init__(self, parent, command=None, width=55, height=28):
        super().__init__(parent, width=width, height=height, bg=C["bg_input"], bd=0, highlightthickness=0, cursor="hand2")
        self.command = command
        self.state = False
        self.width = width
        self.height = height
        
        self.radius = height // 2
        self.circle_radius = self.radius - 2
        
        self.x_off = self.radius
        self.x_on = width - self.radius
        self.current_x = self.x_off
        
        self.bind("<Button-1>", self._toggle)
        self._draw()

    def _draw(self):
        self.delete("all")
        bg_color = C["brand"] if self.state else "#475569"
        
        # Pilule de fond parfaitement lisse
        self.create_oval(0, 0, self.height, self.height, fill=bg_color, outline="")
        self.create_oval(self.width - self.height, 0, self.width, self.height, fill=bg_color, outline="")
        self.create_rectangle(self.radius, 0, self.width - self.radius, self.height, fill=bg_color, outline="")
        
        # Pastille blanche
        self.create_oval(self.current_x - self.circle_radius, self.radius - self.circle_radius,
                         self.current_x + self.circle_radius, self.radius + self.circle_radius,
                         fill="#FFFFFF", outline="")

    def _toggle(self, event):
        self.state = not self.state
        self._animate()
        if self.command:
            self.command(self.state)

    def _animate(self):
        target_x = self.x_on if self.state else self.x_off
        steps = 4
        diff = (target_x - self.current_x) / steps
        
        def step(count):
            if count < steps:
                self.current_x += diff
                self._draw()
                self.after(15, lambda: step(count + 1))
            else:
                self.current_x = target_x
                self._draw()
                
        step(0)

    def set_state(self, state):
        if self.state != state:
            self.state = state
            self.current_x = self.x_on if state else self.x_off
            self._draw()

