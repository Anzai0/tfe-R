# --- COMPOSANT : ANNEAU DE PROGRESSION CIRCULAIRE ---
class CircularProgress(tk.Canvas):
    def __init__(self, parent, label="Capteur", unit="", max_val=100, color="#3B82F6"):
        super().__init__(parent, width=200, height=220, bg=C["bg_card"], bd=0, highlightthickness=0)
        self.label = label
        self.unit = unit
        self.max_val = max_val
        self.color = color
        self.value = 0.0
        self._draw()

    def _draw(self):
        self.delete("all")
        bbox = (20, 20, 180, 180)
        self.create_arc(bbox, start=0, extent=359, outline="#334155", width=14, style="arc")
        extent_angle = -(self.value / self.max_val) * 360 if self.max_val > 0 else 0
        if extent_angle < -360: extent_angle = -360
        if extent_angle != 0:
            self.create_arc(bbox, start=90, extent=extent_angle, outline=self.color, width=14, style="arc")
        
        self.create_text(100, 100, text=f"{self.value}{self.unit}", fill=C["text_main"], font=("Segoe UI", 16, "bold"))
        self.create_text(100, 205, text=self.label, fill=C["text_muted"], font=("Segoe UI", 8, "bold"), justify="center")

    def set_value(self, val):
        self.value = val
        self._draw()

# --- COMPOSANT : COMPOSANT PLUIE PARFAITEMENT HARMONISÉ ---
class RainIndicator(tk.Canvas):
    def __init__(self, parent, label="PLUIE", color="#38BDF8"):
        super().__init__(parent, width=200, height=220, bg=C["bg_card"], bd=0, highlightthickness=0)
        self.label = label
        self.color = color
        self.is_raining = False
        self._draw()

    def _draw(self):
        self.delete("all")
        bbox = (20, 20, 180, 180)
        
        # 1. On dessine l'anneau extérieur coloré identique aux autres cercles
        self.create_arc(bbox, start=0, extent=359, outline=self.color, width=14, style="arc")
        
        # CORRECTION : Le fond intérieur est maintenant STRICTEMENT le même fond que la carte (C["bg_card"])
        inner_bbox = (27, 27, 173, 173)
        self.create_oval(inner_bbox, fill=C["bg_card"], outline="")
        
        # 3. Texte dynamique "Oui" ou "Non" écrit en blanc pur au centre
        text_status = "Oui" if self.is_raining else "Non"
        self.create_text(100, 100, text=text_status, fill="#FFFFFF", font=("Segoe UI", 18, "bold"))
        
        # 4. Label "PLUIE" en bas aligné au millimètre
        self.create_text(100, 205, text=self.label, fill=C["text_muted"], font=("Segoe UI", 8, "bold"), justify="center")

    def set_status(self, is_raining):
        self.is_raining = is_raining
        self._draw()

# --- COMPOSANT : TOGGLE SWITCH ---
class IOSSwitch(tk.Canvas):
    def __init__(self, parent, command=None, width=70, height=26):
        super().__init__(parent, width=width, height=height, bg=C["bg_card"], bd=0, highlightthickness=0, cursor="hand2")
        self.command = command
        self.state = False
        self.width = width
        self.height = height
        self.radius = height // 2
        self.circle_radius = self.radius - 2
        self.x_off = self.radius
        self.x_on = width - self.radius
        self.current_x = self.x_off
        self.bind("<Button-1>", self._toggle)
        self._draw()

    def _draw(self):
        self.delete("all")
        bg_color = C["brand"] if self.state else "#475569"
        self.create_oval(0, 0, self.height, self.height, fill=bg_color, outline="")
        self.create_oval(self.width - self.height, 0, self.width, self.height, fill=bg_color, outline="")
        self.create_rectangle(self.radius, 0, self.width - self.radius, self.height, fill=bg_color, outline="")
        
        if self.state:
            self.create_text(self.radius + 2, self.radius, text="ON", fill="#FFFFFF", font=("Segoe UI", 8, "bold"), anchor="w")
        else:
            self.create_text(self.width - self.radius - 2, self.radius, text="OFF", fill="#E2E8F0", font=("Segoe UI", 8, "bold"), anchor="e")
            
        self.create_oval(self.current_x - self.circle_radius, self.radius - self.circle_radius,
                         self.current_x + self.circle_radius, self.radius + self.circle_radius,
                         fill="#FFFFFF", outline="")

    def _toggle(self, event):
        self.state = not self.state
        self._animate()
        if self.command:
            self.command(self.state, manuel=True)

    def _animate(self):
        target_x = self.x_on if self.state else self.x_off
        steps = 4
        diff = (target_x - self.current_x) / steps
        def step(count):
            if count < steps:
                self.current_x += diff
                self._draw()
                self.after(15, lambda: step(count + 1))
            else:
                self.current_x = target_x
                self._draw()
        step(0)

    def set_state(self, state):
        if self.state != state:
            self.state = state
            self.current_x = self.x_on if state else self.x_off
            self._draw()

