        self.window = tk.Toplevel(parent)
        self.window.geometry("500x250")
        self.window.config(bg=C["fond"])
        self.window.attributes('-topmost', True)
        
        if type_alerte == "danger":
            couleur = C["rouge"]
        elif type_alerte == "warning":
            couleur = C["orange"]
        else:
            couleur = C["bleu"]
        
        barre = tk.Frame(self.window, bg=couleur, height=5)
        barre.pack(fill=tk.X)
        
        titre_label = tk.Label(
            self.window,
            text=titre,
