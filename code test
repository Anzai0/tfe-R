def logique_auto():
    """Logique automatique"""
    while True:
        try:
            if mode_automatique_active:
                temp = donnees_capteurs['temperature']
                humidite = donnees_capteurs['humidite']
                
                # Controle temperature
                if temp > SEUIL_TEMP_MAX and not etat_ventilateur:
                    toggle_ventilateur()
                elif temp < SEUIL_TEMP_MIN and not etat_lumiere:
                    toggle_lumiere()
                
                # Controle humidite
                if humidite > SEUIL_HUMIDITE_MAX and not etat_ventilateur:
                    toggle_ventilateur()
                elif humidite < SEUIL_HUMIDITE_MIN and not etat_humidificateur:
                    toggle_humidificateur()
            
            time.sleep(3)
        except Exception as e:
            print(f"Erreur auto: {e}")
            time.sleep(3)

# ===== THREAD CAPTEURS =====
def lire_capteurs_loop():
    """Boucle de lecture des capteurs"""
    last_alarmes = []
    
    while True:
        try:
            donnees = lire_capteurs()
            if donnees:
                temp = donnees['temperature']
                humidite = donnees['humidite']
                
                donnees_capteurs['temperature'] = temp
                donnees_capteurs['humidite'] = humidite
                donnees_capteurs['heure'] = datetime.now().strftime("%H:%M:%S")
                
                # Historique
                donnees_capteurs['historique_temp'].append(temp)
                donnees_capteurs['historique_humidite'].append(humidite)
                
                if len(donnees_capteurs['historique_temp']) > 120:
                    donnees_capteurs['historique_temp'].pop(0)
                    donnees_capteurs['historique_humidite'].pop(0)
                
                # Verification alarmes
                alarmes = verifier_alarmes(temp, humidite)
                
                if alarmes and alarmes != last_alarmes:
                    alerte_buzzer_async()
                    for titre, msg, type_alerte in alarmes:
                        AlerteWindow(root, titre, msg, type_alerte)
                    last_alarmes = alarmes
                elif not alarmes:
                    last_alarmes = []
                
                donnees_capteurs['alarmes'] = alarmes
                mettre_a_jour_interface()
            
            time.sleep(2)
        except Exception as e:
            print(f"Erreur: {e}")
            time.sleep(2)

# ===== MISE A JOUR INTERFACE =====
def mettre_a_jour_interface():
    """Met a jour l'interface"""
    try:
        temp = donnees_capteurs['temperature']
        humidite = donnees_capteurs['humidite']
        heure = donnees_capteurs['heure']
        
        # Couleur barre de statut
        if temp > SEUIL_TEMP_MAX or humidite > SEUIL_HUMIDITE_MAX:
            barre_statut.config(bg=ACCENT_RED)
            label_status_bar.config(text="ALERTE: Seuils depasses", fg=ACCENT_RED)
        elif temp < SEUIL_TEMP_MIN or humidite < SEUIL_HUMIDITE_MIN:
            barre_statut.config(bg=ACCENT_YELLOW)
            label_status_bar.config(text="ATTENTION: Seuils bas", fg=ACCENT_YELLOW)
        else:
            barre_statut.config(bg=ACCENT_GREEN)
            label_status_bar.config(text="NORMAL: Tous les seuils OK", fg=ACCENT_GREEN)
        
        # Couleurs capteurs
        if temp > SEUIL_TEMP_MAX:
            couleur_temp = ACCENT_RED
        elif temp < SEUIL_TEMP_MIN:
            couleur_temp = ACCENT_BLUE
        else:
            couleur_temp = ACCENT_GREEN
        
        if humidite > SEUIL_HUMIDITE_MAX or humidite < SEUIL_HUMIDITE_MIN:
            couleur_humid = ACCENT_RED
        else:
            couleur_humid = ACCENT_GREEN
        
        # Mettre a jour les labels
        label_temp_value.config(text=f"{temp:.1f}C", fg=couleur_temp)
        label_humid_value.config(text=f"{humidite:.1f}%", fg=couleur_humid)
        label_heure_value.config(text=heure)
        
        # Stats
        if donnees_capteurs['historique_temp']:
            temp_moy = sum(donnees_capteurs['historique_temp']) / len(donnees_capteurs['historique_temp'])
            temp_min = min(donnees_capteurs['historique_temp'])
            temp_max = max(donnees_capteurs['historique_temp'])
            
            label_stats.config(
                text=f"Moyenne: {temp_moy:.1f}C | Min: {temp_min:.1f}C | Max: {temp_max:.1f}C"
            )
    
    except Exception as e:
        print(f"Erreur interface: {e}")

def ajouter_log(message):
    """Ajoute un message au log"""
    timestamp = datetime.now().strftime("%H:%M:%S")
    texte = f"[{timestamp}] {message}\n"
    text_log.config(state=tk.NORMAL)
    text_log.insert(tk.END, texte)
    text_log.see(tk.END)
    text_log.config(state=tk.DISABLED)

