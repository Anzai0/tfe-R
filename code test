        if len(self.plantes) < 3:
            btn_add = tk.Button(card, text="AJOUTER UNE PLANTE",
                                command=self._popup_plante, pady=7)
            btn_style(btn_add)
            btn_add.pack(fill="x", pady=(0, 12))

        self.frame_plantes = tk.Frame(card, bg=C["carte"])
        self.frame_plantes.pack(fill="x")
        self._afficher_plantes()

    def _afficher_plantes(self):
        for w in self.frame_plantes.winfo_children():
            w.destroy()

        if not self.plantes:
            tk.Label(self.frame_plantes,
                     text="Aucune plante - Cliquez sur AJOUTER",
                     font=("Segoe UI", 10, "italic"),
                     bg=C["carte"],
                     fg=C["gris"]).pack(pady=15)
            return

        for idx, plante in enumerate(self.plantes):
            actif = self.plante_active and self.plante_active.get("nom") == plante.get("nom")
            border_color = C["accent"] if actif else C["gris2"]

            c = tk.Frame(self.frame_plantes, bg=border_color, pady=1, padx=1)
            c.pack(fill="x", pady=5)
            inner = tk.Frame(c, bg=C["carte3"] if actif else C["carte2"], padx=14, pady=12)
            inner.pack(fill="x")

            top = tk.Frame(inner, bg=inner.cget("bg"))
            top.pack(fill="x")

            nom_plante = plante.get("nom", f"Plante {idx+1}")
            tk.Label(top, text=nom_plante,
                     font=("Segoe UI", 12, "bold"),
                     bg=inner.cget("bg"),
                     fg=C["accent"] if actif else C["texte"]).pack(side="left")

            if actif:
                tk.Label(top, text="ACTIVE",
                         font=("Segoe UI", 8, "bold"),
                         bg=inner.cget("bg"),
                         fg=C["vert"]).pack(side="left", padx=(10, 0))

            # Infos
            info_frame = tk.Frame(inner, bg=inner.cget("bg"))
            info_frame.pack(fill="x", pady=(8, 0))

            seuils = [
                ("TEMP MAX", f"{plante.get('temp_max', '--')} C"),
                ("HUM MIN", f"{plante.get('humidite_min', '--')} %"),
                ("EAU MIN", f"{plante.get('eau_min', '--')} %"),
            ]

            for label, val in seuils:
                chip = tk.Frame(info_frame, bg=C["gris2"], padx=8, pady=4)
                chip.pack(side="left", padx=(0, 6))
                tk.Label(chip, text=f"{label}: {val}",
                         font=("Segoe UI", 8),
                         bg=C["gris2"],
                         fg=C["texte"]).pack()

            # Boutons
            btn_frame = tk.Frame(inner, bg=inner.cget("bg"))
            btn_frame.pack(fill="x", pady=(10, 0))

            if not actif:
                b_sel = tk.Button(btn_frame, text="SELECTIONNER",
                                   command=lambda p=plante: self._selectionner(p),
                                   pady=5, padx=10)
                btn_style(b_sel)
                b_sel.pack(side="left")

            b_sup = tk.Button(btn_frame, text="SUPPRIMER",
                               command=lambda p=plante: self._supprimer(p),
                               pady=5, padx=10)
            btn_style(b_sup, bg=C["rouge"], fg=C["texte"])
            b_sup.pack(side="right")

    def _popup_plante(self):
        if len(self.plantes) >= 3:
            messagebox.showwarning("Limite", "Maximum 3 plantes autorisees")
            return

        pop = tk.Toplevel(self)
        pop.title("Nouvelle plante")
        pop.configure(bg=C["fond"])
        pop.geometry("420x480")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(pop, text="NOUVELLE PLANTE",
                 font=("Segoe UI", 15, "bold"),
                 bg=C["fond"], fg=C["accent"]).pack(pady=(25, 5))

        card = tk.Frame(pop, bg=C["carte"], padx=30, pady=25)
        card.pack(fill="x", padx=25, pady=20)

        champs = [
            ("NOM DE LA PLANTE", "nom", ""),
            ("TEMPERATURE MAX (C)", "temp_max", "30"),
            ("HUMIDITE MINI (%)", "humidite_min", "50"),
            ("EAU MINI (%)", "eau_min", "30"),
        ]
        entries = {}

        for label, key, default in champs:
            tk.Label(card, text=label, font=("Segoe UI", 9, "bold"),
                     bg=C["carte"], fg=C["gris"]).pack(anchor="w")
            e = tk.Entry(card)
            entry_style(e)
            e.insert(0, default)
            e.pack(fill="x", pady=(4, 12), ipady=8)
            entries[key] = e

        lbl_err = tk.Label(card, text="", font=("Segoe UI", 9),
                            bg=C["carte"], fg=C["rouge"])
        lbl_err.pack()

        def sauvegarder():
            nom = entries["nom"].get().strip()
            if not nom:
                lbl_err.configure(text="Le nom est obligatoire")
                return
            if any(p.get("nom", "").lower() == nom.lower() for p in self.plantes):
                lbl_err.configure(text="Cette plante existe deja")
                return
            try:
                tm = float(entries["temp_max"].get())
                hm = float(entries["humidite_min"].get())
                em = float(entries["eau_min"].get())
            except:
                lbl_err.configure(text="Valeurs numeriques invalides")
                return

            plante = {
                "nom": nom,
                "temp_max": tm,
                "humidite_min": hm,
                "eau_min": em
            }

            try:
                db.child("plantes").child(self.uid).push(plante)
            except Exception as e:
                lbl_err.configure(text=f"Erreur: {e}")
                return

            self.plantes.append(plante)
            if not self.plante_active:
                self.plante_active = plante
            self._afficher_plantes()
            pop.destroy()

        btn = tk.Button(card, text="AJOUTER LA PLANTE",
                         command=sauvegarder, pady=11)
        btn_style(btn, size=11)
        btn.pack(fill="x", pady=(8, 0))

    def _section_historique(self):
        """Section historique"""
        wrapper = tk.Frame(self.inner, bg=C["accent"], pady=1, padx=1)
        wrapper.pack(fill="x", padx=15, pady=8)

        card = tk.Frame(wrapper, bg=C["carte"], padx=20, pady=16)
        card.pack(fill="x")

        tk.Label(
            card,
            text="HISTORIQUE",
            font=("Segoe UI", 11, "bold"),
            bg=C["carte"],
            fg=C["accent"]
        ).pack(anchor="w", pady=(0, 8))

        tk.Frame(card, bg=C["gris2"], height=1).pack(fill="x", pady=(0, 10))

        scrollbar = tk.Scrollbar(card)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

        self.text_log = tk.Text(
            card,
            height=10,
            width=50,
            bg=C["carte2"],
            fg=C["vert"],
            font=("Courier New", 9),
            yscrollcommand=scrollbar.set,
            border=0,
            padx=10,
            pady=10
        )
        self.text_log.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        scrollbar.config(command=self.text_log.yview)
        self.text_log.config(state=tk.DISABLED)

        self._afficher_historique()

    def _afficher_historique(self):
        self.text_log.config(state=tk.NORMAL)
        self.text_log.delete("1.0", tk.END)
        for evt in self.historique[-20:]:
            texte = f"[{evt.get('heure', '--:--:--')}] {evt.get('message', '')}\n"
            self.text_log.insert(tk.END, texte)
        self.text_log.config(state=tk.DISABLED)
        self.text_log.see(tk.END)

    def _ajouter_log(self, message):
        """Ajoute un message au log"""
        timestamp = datetime.now().strftime("%H:%M:%S")
        evt = {"heure": timestamp, "message": message}
        self.historique.append(evt)
        try:
            db.child("historique").child(self.uid).push(evt)
        except:
            pass
        self._afficher_historique()

    def _selectionner(self, plante):
        self.plante_active = plante
        self._afficher_plantes()
        self._ajouter_log(f"Plante selectionnee: {plante.get('nom')}")

    def _supprimer(self, plante):
        if not messagebox.askyesno("Supprimer", f"Supprimer {plante.get('nom')} ?"):
            return
        self.plantes = [p for p in self.plantes if p.get("nom") != plante.get("nom")]
        if self.plante_active and self.plante_active.get("nom") == plante.get("nom"):
            self.plante_active = self.plantes[0] if self.plantes else None
        self._afficher_plantes()
        self._ajouter_log(f"Plante supprimee: {plante.get('nom')}")

    def _toggle_pompe(self):
        self.etat_ventilateur = not self.etat_ventilateur
        if self.etat_ventilateur:
            GPIO.output(HUMIDIFICATEUR_PIN, GPIO.HIGH)
            self.label_pompe_status.configure(text="ACTIVE", fg=C["vert"])
            self.btn_pompe.configure(text="ARRETER", bg=C["rouge"])
            self._ajouter_log("Pompe activee")
        else:
            GPIO.output(HUMIDIFICATEUR_PIN, GPIO.LOW)
            self.label_pompe_status.configure(text="ARRETEE", fg=C["rouge"])
            self.btn_pompe.configure(text="ACTIVER", bg=C["accent"])
            self._ajouter_log("Pompe arretee")
        try:
            db.child("commandes").child(self.uid).update({"pompe": self.etat_ventilateur})
        except:
            pass

    def _toggle_ventilo(self):
        self.etat_humidificateur = not self.etat_humidificateur
        if self.etat_humidificateur:
            GPIO.output(VENTILATEUR_PIN, GPIO.HIGH)
            self.label_ventilo_status.configure(text="ACTIF", fg=C["vert"])
            self.btn_ventilo.configure(text="ARRETER", bg=C["rouge"])
            self._ajouter_log("Ventilateur active")
        else:
            GPIO.output(VENTILATEUR_PIN, GPIO.LOW)
            self.label_ventilo_status.configure(text="ARRETE", fg=C["rouge"])
            self.btn_ventilo.configure(text="ACTIVER", bg=C["accent"])
            self._ajouter_log("Ventilateur arrête")
        try:
            db.child("commandes").child(self.uid).update({"ventilateur": self.etat_humidificateur})
        except:
            pass

    def _lancer_lecteur_capteurs(self):
        """Lance la lecture des capteurs"""
        thread = threading.Thread(target=self._lecteur_capteurs, daemon=True)
        thread.start()

    def _lecteur_capteurs(self):
        """Lit les capteurs DHT22"""
        while True:
            try:
                if dht_device:
                    temp = dht_device.temperature
                    humid = dht_device.humidity
                    if temp is not None and humid is not None:
                        donnees_capteurs['temperature'] = temp
                        donnees_capteurs['humidite'] = humid
                        donnees_capteurs['heure'] = datetime.now().strftime("%H:%M:%S")
                        self.after(0, self._rafraichir_capteurs)
                        self._verifier_alarmes(temp, humid)
                time.sleep(2)
            except Exception as e:
                print(f"Erreur capteur: {e}")
                time.sleep(5)

    def _verifier_alarmes(self, temp, humid):
        """Verifie les alarmes"""
        if self.plante_active:
            temp_max = self.plante_active.get("temp_max", 30)
            humid_min = self.plante_active.get("humidite_min", 50)

            if temp > temp_max:
                alerte_buzzer_async()
                self.after(0, lambda: AlerteWindow(
                    self,
                    "ALERTE TEMPERATURE",
                    f"Temperature trop elevee: {temp:.1f}C (Seuil: {temp_max}C)",
                    "danger"
                ))
                self.after(0, lambda: self.barre.configure(bg=C["rouge"]))
                self.after(0, lambda: self.label_status.configure(
                    text=f"ALERTE: Temperature trop elevee ({temp:.1f}C)",
                    fg=C["rouge"]
                ))

            elif humid < humid_min:
                alerte_buzzer_async()
                self.after(0, lambda: AlerteWindow(
                    self,
                    "ALERTE HUMIDITE",
                    f"Humidite trop basse: {humid:.1f}% (Seuil: {humid_min}%)",
                    "warning"
                ))
                self.after(0, lambda: self.barre.configure(bg=C["orange"]))
                self.after(0, lambda: self.label_status.configure(
                    text=f"ATTENTION: Humidite trop basse ({humid:.1f}%)",
                    fg=C["orange"]
                ))
            else:
                self.after(0, lambda: self.barre.configure(bg=C["vert"]))
                self.after(0, lambda: self.label_status.configure(
                    text="NORMAL - Tous les seuils OK",
                    fg=C["vert"]
                ))

    def _rafraichir_capteurs(self):
        """Met a jour l'affichage des capteurs"""
        temp = donnees_capteurs['temperature']
        humid = donnees_capteurs['humidite']
        heure = donnees_capteurs['heure']

        if temp > 30:
            couleur_temp = C["rouge"]
        elif temp < 15:
            couleur_temp = C["bleu"]
        else:
            couleur_temp = C["vert"]

        if humid > 80 or humid < 30:
            couleur_humid = C["rouge"]
        else:
            couleur_humid = C["vert"]

        self.label_temp.configure(text=f"{temp:.1f} C", fg=couleur_temp)
        self.label_humidite.configure(text=f"{humid:.1f} %", fg=couleur_humid)
        self.label_heure.configure(text=heure)

    def _rafraichir_capteurs(self):
        """Rafraichit les donnees capteurs"""
        self.label_temp.configure(
            text=f"{donnees_capteurs['temperature']:.1f} C",
            fg=C["vert"] if 15 < donnees_capteurs['temperature'] < 30 else C["rouge"]
        )
        self.label_humidite.configure(
            text=f"{donnees_capteurs['humidite']:.1f} %",
            fg=C["vert"] if 30 < donnees_capteurs['humidite'] < 80 else C["rouge"]
        )
        self.label_heure.configure(text=donnees_capteurs['heure'])

# ===== APPLICATION PRINCIPALE =====
class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("Serre Connectee")
        self.fen.configure(bg=C["fond"])
        self.fen.geometry("900x700")
        self.fen.resizable(False, False)

        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page:
            self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page:
            self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def lancer(self):
        self.fen.mainloop()

if __name__ == "__main__":
    App().lancer()
