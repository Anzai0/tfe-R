# ===== FONCTION BUZZER =====
def sonner_buzzer(duree=0.3, fois=3):
    """Buzzer avec pattern de son"""
    for i in range(fois):
        GPIO.output(BUZZER_PIN, GPIO.HIGH)
        time.sleep(duree)
        GPIO.output(BUZZER_PIN, GPIO.LOW)
        time.sleep(duree * 0.5)

def alerte_buzzer_async():
    """Lance le buzzer en thread"""
    thread = threading.Thread(target=sonner_buzzer, args=(0.2, 5), daemon=True)
    thread.start()

# ===== FONCTIONS CAPTEURS =====
def lire_capteurs():
    """Lit les capteurs DHT22"""
    try:
        if dht_device is None:
            # Simulation
            import random
            return {
                'temperature': 22 + random.uniform(-2, 2),
                'humidite': 60 + random.uniform(-10, 10)
            }
        
        temperature = dht_device.temperature
        humidite = dht_device.humidity
        
        if temperature is not None and humidite is not None:
            return {
                'temperature': temperature,
                'humidite': humidite
            }
    except RuntimeError:
        pass
    
    return None

def verifier_alarmes(temp, humidite):
    """Vérifie les seuils de danger"""
    alarmes = []
    
    if temp > SEUIL_TEMP_MAX:
        alarmes.append(("TEMPERATURE TROP ELEVEE", f"Temperature: {temp:.1f}C - Seuil Max: {SEUIL_TEMP_MAX}C", "danger"))
    elif temp < SEUIL_TEMP_MIN:
        alarmes.append(("TEMPERATURE TROP BASSE", f"Temperature: {temp:.1f}C - Seuil Min: {SEUIL_TEMP_MIN}C", "warning"))
    
    if humidite > SEUIL_HUMIDITE_MAX:
        alarmes.append(("HUMIDITE TROP ELEVEE", f"Humidite: {humidite:.1f}% - Seuil Max: {SEUIL_HUMIDITE_MAX}%", "danger"))
    elif humidite < SEUIL_HUMIDITE_MIN:
        alarmes.append(("HUMIDITE TROP BASSE", f"Humidite: {humidite:.1f}% - Seuil Min: {SEUIL_HUMIDITE_MIN}%", "warning"))
    
    return alarmes

