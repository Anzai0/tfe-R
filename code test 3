    def _render_plantes(self):
        for w in self.plant_section.winfo_children(): w.destroy()
        
        top_bar = tk.Frame(self.plant_section, bg=C["bg_card"])
        top_bar.pack(fill="x", pady=(0, 10))
        tk.Label(top_bar, text=f"CONFIGURATIONS CYBLES ({len(self.plantes)}/3)", font=("Segoe UI", 10, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(side="left")
        
        if len(self.plantes) < 3:
            btn_add = tk.Button(top_bar, text="+ Ajouter une cible", command=self._popup_plante, px=10)
            style_btn(btn_add, bg=C["accent"], fg=C["bg_main"])
            btn_add.pack(side="right")

        if not self.plantes:
            tk.Label(self.plant_section, text="Aucun profil enregistré. Automatisation inactive.", font=("Segoe UI", 10, "italic"), bg=C["bg_card"], fg=C["text_muted"]).pack(pady=30)
            return

        for p in self.plantes:
            is_active = self.plante_active and self.plante_active["nom"] == p["nom"]
            bg_item = C["bg_input"] if is_active else C["bg_card"]
            b_color = C["accent"] if is_active else C["border"]

            item = tk.Frame(self.plant_section, bg=bg_item, highlightthickness=1, highlightbackground=b_color, padx=15, pady=10)
            item.pack(fill="x", pady=4)

            lbl_name = tk.Label(item, text=p["nom"].upper(), font=("Segoe UI", 11, "bold"), bg=bg_item, fg=C["text_main"] if not is_active else C["accent"])
            lbl_name.pack(side="left")

            if is_active:
                tk.Label(item, text="[PROFIL SURVEILLÉ]", font=("Segoe UI", 8, "bold"), bg=bg_item, fg=C["accent"]).pack(side="left", padx=10)

            # Conteneurs de badges de données
            badge_box = tk.Frame(item, bg=bg_item)
            badge_box.pack(side="right")

            for txt, c in [(f"Max T°: {p['temp_max']}°C", C["info"]), (f"Min Sol: {p['eau_min']}%", C["warning"])]:
                b = tk.Frame(badge_box, bg=C["bg_main"], padx=6, pady=2)
                b.pack(side="left", padx=4)
                tk.Label(b, text=txt, font=("Segoe UI", 8), bg=C["bg_main"], fg=C["text_main"]).pack()

            if not is_active:
                b_sel = tk.Button(badge_box, text="Suivre", command=lambda pl=p: self._select_plante(pl))
                style_btn(b_sel, bg=C["border"], fg=C["text_main"])
                b_sel.pack(side="left", padx=10)
            
            b_del = tk.Button(badge_box, text="X", command=lambda pl=p: self._suppr_plante(pl))
            style_btn(b_del, bg=C["danger"], fg=C["text_main"])
            b_del.pack(side="left", padx=4)

    def _select_plante(self, p):
        self.plante_active = p
        self._render_plantes()
        self._log("INFO", f"Changement de profil cible : Surveillance de la plante [{p['nom']}]")

    def _suppr_plante(self, p):
        if not messagebox.askyesno("Confirmation", f"Supprimer définitivement le profil '{p['nom']}' ?"): return
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("DELETE FROM plantes WHERE uid=%s AND nom=%s", (self.uid, p["nom"]))
            conn.commit(); cur.close(); conn.close()
            self.plantes = [x for x in self.plantes if x["nom"] != p["nom"]]
            if self.plante_active and self.plante_active["nom"] == p["nom"]:
                self.plante_active = self.plantes[0] if self.plantes else None
            self._render_plantes()
            self._log("WARN", f"Profil '{p['nom']}' supprimé de la base locale.")
        except Exception as e:
            self._log("ERR", f"Erreur SQL Suppression: {e}")

    def _popup_plante(self):
        pop = tk.Toplevel(self)
        pop.title("Nouveau Profil")
        pop.configure(bg=C["bg_main"])
        pop.geometry("380x420")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(pop, text="Nouveau Profil Végétal", font=("Segoe UI", 14, "bold"), bg=C["bg_main"], fg=C["text_main"]).pack(pady=(20, 20))
        
        f_fields = tk.Frame(pop, bg=C["bg_card"], padx=20, pady=20, highlightthickness=1, highlightbackground=C["border"])
        f_fields.pack(fill="both", expand=True, padx=20, pady=(0, 20))

        fields = [("NOM DE LA PLANTE", "nom", ""), ("TEMPÉRATURE MAX (C°)", "t_max", "30"), ("HUMIDITÉ SOL MIN (%)", "e_min", "40")]
        entries = {}

        for label, key, default in fields:
            tk.Label(f_fields, text=label, font=("Segoe UI", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w", pady=(5,0))
            e = tk.Entry(f_fields)
            style_entry(e)
            e.insert(0, default)
            e.pack(fill="x", pady=(3, 10), ipady=6)
            entries[key] = e

        lbl_err = tk.Label(f_fields, text="", font=("Segoe UI", 9), bg=C["bg_card"], fg=C["danger"])
        lbl_err.pack()

        def valider():
            nom = entries["nom"].get().strip()
            if not nom: lbl_err.configure(text="Le nom est requis."); return
            try:
                tm = float(entries["t_max"].get())
                em = float(entries["e_min"].get())
            except: lbl_err.configure(text="Valeurs numériques invalides."); return

            try:
                conn = get_db(); cur = conn.cursor()
                cur.execute("INSERT INTO plantes (uid,nom,temp_max,humidite_min,eau_min) VALUES (%s,%s,%s,%s,%s)", (self.uid, nom, tm, 0.0, em))
                conn.commit(); cur.close(); conn.close()
                self.plantes.append({"nom": nom, "temp_max": tm, "humidite_min": 0.0, "eau_min": em})
                if not self.plante_active: self.plante_active = self.plantes[0]
                self._render_plantes()
                self._log("OK", f"Nouveau profil enregistré avec succès : {nom}")
                pop.destroy()
            except Exception as ex:
                lbl_err.configure(text=f"Erreur DB : {ex}")

        btn_save = tk.Button(f_fields, text="Enregistrer l'objectif", command=valider)
        style_btn(btn_save)
        btn_save.pack(fill="x", ipady=5, pady=(10, 0))

    # --- TRANSMISSION TEMPS RÉEL (VERS LE RASPBERRY PI VIA FIREBASE) ---
    def _tog_pompe(self):
        self.pompe_on = not self.pompe_on
        self._update_button_ui(self.btn_pompe, self.pompe_on)
        self._log("OK" if self.pompe_on else "WARN", f"Ordre utilisateur : Pompe demandée -> {'ALLUMÉE' if self.pompe_on else 'ÉTEINTE'}")
        threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"pompe": self.pompe_on}), daemon=True).start()

    def _tog_ventilo(self):
        self.ventilo_on = not self.ventilo_on
        self._update_button_ui(self.btn_ventilo, self.ventilo_on)
        self._log("OK" if self.ventilo_on else "WARN", f"Ordre utilisateur : Ventilateur demandé -> {'ALLUMÉE' if self.ventilo_on else 'ÉTEINTE'}")
        threading.Thread(target=lambda: db.child("commandes").child(self.uid).update({"ventilateur": self.ventilo_on}), daemon=True).start()

    def _update_button_ui(self, btn, state):
        if state:
            btn.configure(text="DÉSACTIVER", bg=C["danger"], fg=C["text_main"], activebackground=C["danger"])
        else:
            btn.configure(text="ACTIVER", bg=C["border"], fg=C["text_main"], activebackground=C["accent"])

    # --- MOTEUR D'AUTOMATISATION ET DE TRAITEMENT DES FLUX ---
    def _rafraichir_donnees(self):
        def tache():
            try:
                d = db.child("capteurs").child(self.uid).get().val()
                if d:
                    self.after(0, self._process_telemetrie, d)
                else:
                    self._log("WARN", "En attente du flux de données émis par le Raspberry Pi...")
            except Exception as e:
                self._log("ERR", f"Échec de synchronisation Firebase Cloud : {e}")
            self.after(5000, self._rafraichir_donnees)
        threading.Thread(target=tache, daemon=True).start()

    def _process_telemetrie(self, data):
        temp = data.get("temperature", 0.0)
        hum = data.get("humidite_air", 0.0)
        sol = data.get("humidite_sol", 0.0)
        pluie = data.get("pluie", False)

        # 1. Mise à jour Interface Graphique des Cartes
        for key, val in [("temp", temp), ("hum", hum), ("sol", sol)]:
            lbl, bar, unit, _ = self._cards_widgets[key]
            lbl.configure(text=f"{val} {unit}")
            ratio = min(max(val / 100.0 if key != "temp" else val / 50.0, 0.0), 1.0)
            bar.place(relwidth=ratio)
            
        # Cas spécial capteur binaire Pluie
        lbl, bar, _, _ = self._cards_widgets["pluie"]
        lbl.configure(text="DÉTECTÉE" if pluie else "AUCUNE", fg=C["info"] if pluie else C["text_main"])
        bar.place(relwidth=1.0 if pluie else 0.05)

        self._log("INFO", f"Télémétrie reçue -> Air: {temp}°C | Hum: {hum}% | Sol: {sol}% | Pluie: {'Oui' if pluie else 'Non'}")

        # 2. Sauvegarde dans l'Historique local (MariaDB)
        try:
            conn = get_db(); cur = conn.cursor()
            cur.execute("INSERT INTO capteurs (uid,temperature,humidite_air,humidite_sol,pluie) VALUES (%s,%s,%s,%s,%s)", (self.uid, temp, hum, sol, pluie))
            conn.commit(); cur.close(); conn.close()
        except Exception as e:
            self._log("ERR", f"Historisation locale échouée (MariaDB) : {e}")

        # 3. Système d'IA / Régulation automatique des Seuils de la Plante active
        if self.plante_active:
            # Vérification Humidité du sol -> Gestion automatique Pompe
            if sol < self.plante_active["eau_min"] and not self.pompe_on:
                self._log("WARN", f"Seuil critique franchi ! Humidité sol ({sol}%) < Objectif ({self.plante_active['eau_min']}%). Activation automatique de la pompe.")
                self.pompe_on = True
                self._update_button_ui(self.btn_pompe, True)
                db.child("commandes").child(self.uid).update({"pompe": True})
            elif sol >= self.plante_active["eau_min"] + 10 and self.pompe_on: # +10 marge d'arrêt pour éviter les micro-coupures
                self._log("OK", f"Niveau d'eau optimal rétabli ({sol}%). Extinction automatique de la pompe.")
                self.pompe_on = False
                self._update_button_ui(self.btn_pompe, False)
                db.child("commandes").child(self.uid).update({"pompe": False})

            # Vérification Température -> Gestion automatique Ventilateur
            if temp > self.plante_active["temp_max"] and not self.ventilo_on:
                self._log("WARN", f"Surchauffe détectée ! Température ({temp}°C) > Max autorisé ({self.plante_active['temp_max']}°C). Démarrage du système de refroidissement.")
                self.ventilo_on = True
                self._update_button_ui(self.btn_ventilo, True)
                db.child("commandes").child(self.uid).update({"ventilateur": True})
            elif temp <= self.plante_active["temp_max"] - 2 and self.ventilo_on:
                self._log("OK", f"Température stabilisée ({temp}°C). Arrêt du ventilateur.")
                self.ventilo_on = False
                self._update_button_ui(self.btn_ventilo, False)
                db.child("commandes").child(self.uid).update({"ventilateur": False})

    def _log(self, level, msg):
        self.after(0, self._log_ui, level, msg)

    def _log_ui(self, level, msg):
        self.console.configure(state="normal")
        ts = time.strftime("%H:%M:%S")
        self.console.insert("end", f"[{ts}] ", "TEXT_MUTED")
        self.console.insert("end", f"[{level}] ", level)
        self.console.insert("end", f"{msg}\n")
        self.console.configure(state="disabled")
        self.console.see("end")

    def _clear_console(self):
        self.console.configure(state="normal")
        self.console.delete("1.0", "end")
        self.console.configure(state="disabled")


# --- APPLICATION CORE MASTER ---
class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("Greenhouse Management System OS")
        self.fen.geometry("1020://localhost" if False else "1050x760")
        self.fen.configure(bg=C["bg_main"])
        self.fen.resizable(True, True)
        
        init_db()
        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page: self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page: self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def run(self):
        self.fen.mainloop()

if __name__ == "__main__":
    App().run()
