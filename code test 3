def init_db():
    try:
        conn = get_db(); cur = conn.cursor()
        cur.execute("""CREATE TABLE IF NOT EXISTS capteurs (
            id INT AUTO_INCREMENT PRIMARY KEY, uid VARCHAR(255), 
            temperature FLOAT, humidite_air FLOAT, humidite_sol FLOAT, pluie BOOLEAN,
            timestamp DATETIME DEFAULT CURRENT_TIMESTAMP)""")
        cur.execute("""CREATE TABLE IF NOT EXISTS plantes (
            id INT AUTO_INCREMENT PRIMARY KEY, uid VARCHAR(255), nom VARCHAR(100),
            temp_max FLOAT, humidite_min FLOAT, eau_min FLOAT)""")
        conn.commit(); cur.close(); conn.close()
    except Exception as e:
        print(f"[DB] Erreur init: {e}")

# --- STYLISATION DES COMPOSANTS ---
def style_entry(e):
    e.configure(bg=C["bg_input"], fg=C["text_main"], insertbackground=C["accent"],
                relief="flat", bd=0, font=("Consolas", 11),
                highlightthickness=1, highlightbackground=C["border"],
                highlightcolor=C["accent"])

def style_btn(b, bg=None, fg=None):
    b.configure(bg=bg or C["accent"], fg=fg or C["bg_main"],
                relief="flat", bd=0, font=("Segoe UI", 10, "bold"),
                cursor="hand2", activebackground=C["accent"],
                activeforeground=C["bg_main"])

# --- VUE 1 : CONNEXION ET INSCRIPTION RE-STYLISÉE ---
class PageConnexion(tk.Frame):
    def __init__(self, parent, on_conn):
        super().__init__(parent, bg=C["bg_main"])
        self.on_conn = on_conn
        self.mode = "connexion"
        self._build()

    def _build(self):
        # Grand conteneur central effet "bunker cyber"
        container = tk.Frame(self, bg=C["bg_card"], padx=45, pady=45, highlightthickness=2, highlightbackground=C["border"])
        container.place(relx=0.5, rely=0.5, anchor="center", width=440)

        # Badge "SYSTEM"
        badge = tk.Label(container, text="✦ SECURE PROTOCOL", font=("Consolas", 8, "bold"), bg=C["border"], fg=C["accent"], padx=8, pady=3)
        badge.pack(anchor="w", pady=(0, 15))

        self.lbl_title = tk.Label(container, text="CONNEXION", font=("Segoe UI", 26, "bold"), bg=C["bg_card"], fg=C["text_main"])
        self.lbl_title.pack(anchor="w", pady=(0, 2))
        
        self.lbl_subtitle = tk.Label(container, text="SERRE CONNECTÉE", font=("Segoe UI", 9, "bold"), bg=C["bg_card"], fg=C["text_muted"])
        self.lbl_subtitle.pack(anchor="w", pady=(0, 30))

        # Champ Email
        tk.Label(container, text="IDENTIFIANT EMAIL", font=("Consolas", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_email = tk.Entry(container)
        style_entry(self.e_email)
        self.e_email.pack(fill="x", pady=(5, 20), ipady=10)

        # Champ Mot de passe
        tk.Label(container, text="CLEF DE SÉCURITÉ (PASSWORD)", font=("Consolas", 8, "bold"), bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w")
        self.e_mdp = tk.Entry(container, show="*")
        style_entry(self.e_mdp)
        self.e_mdp.pack(fill="x", pady=(5, 25), ipady=10)

        # Bouton Soumettre
        self.btn_submit = tk.Button(container, text="INITIALISER LA SESSION", command=self._action)
        style_btn(self.btn_submit)
        self.btn_submit.pack(fill="x", ipady=8, pady=(0, 20))

        # Switch Mode Toggle
        self.btn_switch = tk.Button(container, text="[ Créer un nouveau compte d'accès ]", bg=C["bg_card"], fg=C["info"], 
                                    bd=0, font=("Consolas", 9), cursor="hand2", activebackground=C["bg_card"], activeforeground=C["text_main"])
        self.btn_switch.configure(command=self._toggle_mode)
        self.btn_switch.pack()

        self.lbl_msg = tk.Label(container, text="", font=("Segoe UI", 9), bg=C["bg_card"], fg=C["danger"])
        self.lbl_msg.pack(pady=(15, 0))

    def _toggle_mode(self):
        if self.mode == "connexion":
            self.mode = "inscription"
            self.lbl_title.configure(text="INSCRIPTION")
            self.btn_submit.configure(text="CRÉER LE COMPTE SYS")
            self.btn_switch.configure(text="[ Retour à l'écran d'authentification ]")
        else:
            self.mode = "connexion"
            self.lbl_title.configure(text="CONNEXION")
            self.btn_submit.configure(text="INITIALISER LA SESSION")
            self.btn_switch.configure(text="[ Créer un nouveau compte d'accès ]")

    def _action(self):
        email = self.e_email.get().strip()
        mdp = self.e_mdp.get().strip()
        if not email or not mdp:
            self.lbl_msg.configure(text="Erreur : Tous les secteurs d'information requis sont vides.")
            return
        
        self.btn_submit.configure(state="disabled", text="REQUÊTE EN COURS...")
        
        def tache():
            try:
                if self.mode == "connexion":
                    user = auth.sign_in_with_email_and_password(email, mdp)
                else:
                    user = auth.create_user_with_email_and_password(email, mdp)
                uid = user["localId"]
                self.after(0, lambda: self.on_conn(uid, email))
            except Exception as e:
                s = str(e)
                msg = "Échec d'authentification réseau."
                if "EMAIL_EXISTS" in s: msg = "Cet email possède déjà un accès."
                elif "WEAK_PASSWORD" in s: msg = "Sécurité trop faible (6 caractères min)."
                elif "INVALID_EMAIL" in s: msg = "Structure d'adresse email invalide."
                elif "EMAIL_NOT_FOUND" in s or "INVALID_PASSWORD" in s: msg = "Identifiants rejetés par la base cloud."
                
                self.after(0, lambda: [
                    self.lbl_msg.configure(text=msg),
                    self.btn_submit.configure(state="normal", text="INITIALISER LA SESSION" if self.mode == "connexion" else "CRÉER LE COMPTE SYS")
                ])
        threading.Thread(target=tache, daemon=True).start()


