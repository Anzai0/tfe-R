# ===== CLASSE GPIO MANAGER =====
class GPIOManager:
    def __init__(self):
        self.pompe_on = False
        self.ventilo_on = False
        self.init_pins()
    
    def init_pins(self):
        if RASPBERRY_OK:
            try:
                GPIO.setup(PIN_POMPE, GPIO.OUT, initial=GPIO.LOW)
                GPIO.setup(PIN_VENTILO, GPIO.OUT, initial=GPIO.LOW)
                GPIO.setup(PIN_BUZZER, GPIO.OUT, initial=GPIO.LOW)
                print("✅ Pins initialises")
            except Exception as e:
                print(f"❌ Erreur GPIO init: {e}")
    
    def toggle_pompe(self):
        self.pompe_on = not self.pompe_on
        print(f"🔧 Pompe: {self.pompe_on}")
        if RASPBERRY_OK:
            try:
                GPIO.output(PIN_POMPE, GPIO.HIGH if self.pompe_on else GPIO.LOW)
                print(f"✅ GPIO17 set to {GPIO.HIGH if self.pompe_on else GPIO.LOW}")
            except Exception as e:
                print(f"❌ Erreur pompe: {e}")
        return self.pompe_on
    
    def toggle_ventilo(self):
        self.ventilo_on = not self.ventilo_on
        print(f"🔧 Ventilo: {self.ventilo_on}")
        if RASPBERRY_OK:
            try:
                GPIO.output(PIN_VENTILO, GPIO.HIGH if self.ventilo_on else GPIO.LOW)
                print(f"✅ GPIO27 set to {GPIO.HIGH if self.ventilo_on else GPIO.LOW}")
            except Exception as e:
                print(f"❌ Erreur ventilo: {e}")
        return self.ventilo_on
    
    def buzz(self, duree=0.5):
        if RASPBERRY_OK:
            try:
                GPIO.output(PIN_BUZZER, GPIO.HIGH)
                time.sleep(duree)
                GPIO.output(PIN_BUZZER, GPIO.LOW)
            except:
                pass
    
    def cleanup(self):
        if RASPBERRY_OK:
            try:
                GPIO.cleanup()
            except:
                pass

gpio = GPIOManager()

