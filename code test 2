            font=("Segoe UI", 28, "bold"),
            bg=C["fond"],
            fg=C["cyan"]
        ).pack()

        tk.Label(
            logo_frame,
            text="Gestion intelligente de vos plantes 🤖",
            font=("Segoe UI", 10),
            bg=C["fond"],
            fg=C["gris"]
        ).pack(pady=(8, 0))

