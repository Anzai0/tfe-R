class ConsolePanel(tk.Frame):
    def __init__(self, parent):
        super().__init__(parent, bg=C["carte"])
        self.logs = []
        self._build()
        self.log_event("🟢 Console demarree", "success")

    def _build(self):
        # HEADER
        hdr = tk.Frame(self, bg=C["carte3"], padx=15, pady=12)
        hdr.pack(fill="x")
        
        tk.Label(
            hdr,
            text="🖥️  CONSOLE",
            font=("Segoe UI", 11, "bold"),
            bg=C["carte3"],
            fg=C["cyan"]
        ).pack(anchor="w")
        
        # GRADIENT
        tk.Frame(self, bg=C["accent"], height=1).pack(fill="x")
        
        # ZONE LOGS
        wrap = tk.Frame(self, bg=C["fond2"])
        wrap.pack(fill="both", expand=True)
        
        self.text = tk.Text(
            wrap,
            bg=C["fond2"],
            fg=C["cyan"],
            font=("Courier New", 8),
            insertbackground=C["accent"],
            wrap="word",
            relief="flat",
            bd=0,
            padx=10,
            pady=8,
            highlightthickness=0,
            state="disabled"
        )
        self.text.pack(fill="both", expand=True, side="left")
        
        # SCROLLBAR
        sb = tk.Scrollbar(wrap, command=self.text.yview, bg=C["carte"], troughcolor=C["fond2"])
        sb.pack(side="right", fill="y", padx=(0, 2))
        self.text.configure(yscrollcommand=sb.set)
        
        # TAGS COULEURS
        self.text.tag_configure("success", foreground=C["vert"])
        self.text.tag_configure("error", foreground=C["rouge"])
        self.text.tag_configure("info", foreground=C["bleu"])
        self.text.tag_configure("warning", foreground=C["orange"])
        self.text.tag_configure("time", foreground=C["gris"])
        self.text.tag_configure("firebase", foreground=C["rose"])
        self.text.tag_configure("capteur", foreground=C["orange"])
        self.text.tag_configure("pompe", foreground=C["bleu"])
        self.text.tag_configure("ventilo", foreground=C["cyan"])

    def log_event(self, message, log_type="info"):
        """Ajoute un log"""
        timestamp = datetime.now().strftime("%H:%M:%S")
        
        icons = {
            "success": "✅",
            "error": "❌",
            "info": "ℹ️ ",
            "warning": "⚠️ ",
            "firebase": "🔥",
            "capteur": "📊",
            "pompe": "💧",
            "ventilo": "💨",
        }
        
        icon = icons.get(log_type, "•")
        
        self.text.configure(state="normal")
        self.text.insert("end", f"[{timestamp}] ", "time")
        self.text.insert("end", f"{icon} ", log_type)
        self.text.insert("end", f"{message}\n", log_type)
        self.text.see("end")
        self.text.configure(state="disabled")
        
        self.logs.append({
            "time": timestamp,
            "type": log_type,
            "message": message,
            "icon": icon
        })


