    def _charger_plantes(self):
        """Charge les plantes Firebase"""
        try:
            response = db.child("plantes").child(self.uid).get()
            if response.val():
                self.plantes = [
                    {
                        "nom": k,
                        "temp_max": v.get("temp_max", 30),
                        "humidite_min": v.get("humidite_min", 50),
                        "eau_min": v.get("eau_min", 30)
                    }
                    for k, v in response.val().items()
                ]
            else:
                self.plantes = []
            
            if self.plantes:
                self.plante_active = self.plantes[0]
            
            self.after(0, self._afficher_plantes)
            self.console.log_event(f"{len(self.plantes)} plante(s) chargee(s)", "success")
        except Exception as e:
            self.console.log_event(f"Erreur chargement: {e}", "error")

    def _afficher_plantes(self):
        """Affiche liste plantes"""
        for w in self.frame_liste.winfo_children():
            w.destroy()

        self.lbl_compteur.configure(text=f"📊 {len(self.plantes)}/3")

        if len(self.plantes) >= 3:
            self.btn_add_plante.configure(
                state="disabled",
                text="🔒 LIMITE ATTEINTE (3/3)",
                bg=C["gris2"]
            )
        else:
            self.btn_add_plante.configure(state="normal", text=f"➕ AJOUTER ({len(self.plantes)}/3)")
            btn_style(self.btn_add_plante, bg=C["bleu"], size=10)

        if not self.plantes:
            tk.Label(
                self.frame_liste,
                text="🌍 Aucune plante - Cliquez AJOUTER",
                font=("Segoe UI", 9, "italic"),
                bg=C["carte"],
                fg=C["gris"]
            ).pack(pady=16)
            return

        for idx, plante in enumerate(self.plantes):
            actif = self.plante_active and self.plante_active["nom"] == plante["nom"]
            border = C["accent"] if actif else C["gris2"]

            c = tk.Frame(self.frame_liste, bg=border, pady=1, padx=1)
            c.pack(fill="x", pady=5)
            
            inner = tk.Frame(c, bg=C["carte3"] if actif else C["carte2"], padx=14, pady=12)
            inner.pack(fill="x")

            top = tk.Frame(inner, bg=inner.cget("bg"))
            top.pack(fill="x", anchor="w")

            tk.Label(
                top,
                text=f"🌿 [{idx+1}/3] {plante['nom']}",
                font=("Segoe UI", 11, "bold"),
                bg=inner.cget("bg"),
                fg=C["accent"]
            ).pack(side="left")

            if actif:
                tk.Label(top, text="✓", font=("Segoe UI", 10, "bold"), bg=inner.cget("bg"), fg=C["vert"]).pack(side="left", padx=(8, 0))

            info = tk.Frame(inner, bg=inner.cget("bg"))
            info.pack(fill="x", pady=(8, 0))

            for ico, label, val, unit in [
                ("🌡️", "Temp", plante["temp_max"], "°C"),
                ("💨", "Hum", plante["humidite_min"], "%"),
                ("💧", "Eau", plante["eau_min"], "%"),
            ]:
                chip = tk.Frame(info, bg=C["gris2"], padx=8, pady=4)
                chip.pack(side="left", padx=(0, 6))
                tk.Label(
                    chip,
                    text=f"{ico} {label}: {val}{unit}",
                    font=("Segoe UI", 7),
                    bg=C["gris2"],
                    fg=C["texte"]
                ).pack()

            btn_frame = tk.Frame(inner, bg=inner.cget("bg"))
            btn_frame.pack(fill="x", pady=(8, 0))

            if not actif:
                b_sel = tk.Button(
                    btn_frame,
                    text="📍 SELECT",
                    command=lambda p=plante: self._select(p),
                    relief="flat"
                )
                btn_style(b_sel, bg=C["bleu"], size=8)
                b_sel.pack(side="left", padx=(0, 4))

            b_del = tk.Button(
                btn_frame,
                text="🗑️",
                command=lambda p=plante: self._supprimer(p),
                relief="flat",
                width=3
            )
            btn_style(b_del, bg=C["rouge"], fg=C["texte"], size=8)
            b_del.pack(side="right")

    def _popup_plante(self):
        if len(self.plantes) >= 3:
            messagebox.showwarning("Limite", "🔒 Maximum 3 plantes!")
            return

        pop = tk.Toplevel(self)
        pop.title("➕ NOUVELLE PLANTE")
        pop.configure(bg=C["fond"])
        pop.geometry("450x520")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(
            pop,
            text="🌱 NOUVELLE PLANTE",
            font=("Segoe UI", 14, "bold"),
            bg=C["fond"],
            fg=C["accent"]
        ).pack(pady=(24, 6))

        tk.Frame(pop, bg=C["accent"], height=2).pack(fill="x", pady=12)

        card = tk.Frame(pop, bg=C["carte"], padx=28, pady=24)
        card.pack(fill="x", padx=20, pady=16)

        champs = [
            ("🌿 NOM", "nom", ""),
            ("🌡️  TEMP MAX (°C)", "temp_max", "30"),
            ("💨 HUMIDITE MIN (%)", "humidite_min", "50"),
            ("💧 EAU MIN (%)", "eau_min", "30"),
        ]
        entries = {}
        
        for label, key, default in champs:
            tk.Label(
                card,
                text=label,
                font=("Segoe UI", 9, "bold"),
                bg=C["carte"],
                fg=C["accent"]
            ).pack(anchor="w")
            e = tk.Entry(card)
            entry_style(e)
            e.insert(0, default)
            e.pack(fill="x", pady=(4, 12), ipady=9)
            entries[key] = e

        lbl_err = tk.Label(card, text="", font=("Segoe UI", 8), bg=C["carte"], fg=C["rouge"])
        lbl_err.pack()

        def save():
            nom = entries["nom"].get().strip()
            if not nom:
                lbl_err.configure(text="❌ Nom obligatoire")
                return
            if any(p["nom"].lower() == nom.lower() for p in self.plantes):
                lbl_err.configure(text="⚠️  Deja existe")
                return
            try:
                tm = float(entries["temp_max"].get())
                hm = float(entries["humidite_min"].get())
                em = float(entries["eau_min"].get())
            except:
                lbl_err.configure(text="❌ Valeurs invalides")
                return

            def firebase_save():
                try:
                    db.child("plantes").child(self.uid).child(nom).set({
                        "temp_max": tm,
                        "humidite_min": hm,
                        "eau_min": em
                    })
                    self.plantes.append({"nom": nom, "temp_max": tm, "humidite_min": hm, "eau_min": em})
                    if not self.plante_active:
                        self.plante_active = self.plantes[0]
                    self.after(0, self._afficher_plantes)
                    self.console.log_event(f"'{nom}' ajoutee ✅", "success")
                    pop.destroy()
                except Exception as e:
                    self.console.log_event(f"Erreur: {e}", "error")

            threading.Thread(target=firebase_save, daemon=True).start()

        btn = tk.Button(card, text="✅ CREER", command=save, relief="flat")
        btn_style(btn, size=11)
        btn.pack(fill="x", pady=(6, 0))

    def _select(self, plante):
        self.plante_active = plante
        self._afficher_plantes()
        self.console.log_event(f"'{plante['nom']}' selectionnee", "info")

    def _supprimer(self, plante):
        if not messagebox.askyesno("Supprimer", f"Supprimer '{plante['nom']}'?"):
            return
        
        def del_firebase():
            try:
                db.child("plantes").child(self.uid).child(plante["nom"]).remove()
                self.plantes = [p for p in self.plantes if p["nom"] != plante["nom"]]
                if self.plante_active and self.plante_active["nom"] == plante["nom"]:
                    self.plante_active = self.plantes[0] if self.plantes else None
                self.after(0, self._afficher_plantes)
                self.console.log_event(f"'{plante['nom']}' supprimee", "warning")
            except Exception as e:
                self.console.log_event(f"Erreur: {e}", "error")

        threading.Thread(target=del_firebase, daemon=True).start()

    def _toggle_pompe(self):
        """ACTIVE LA POMPE GPIO + Firebase"""
        print("💧 CLICK POMPE")
        etat = gpio.toggle_pompe()
        
        if etat:
            self.lbl_pompe.configure(text="● MARCHE", fg=C["vert"])
            self.btn_pompe.configure(text="⏹️  ARRETER")
            btn_style(self.btn_pompe, bg=C["rouge"], size=10)
            self.console.log_event("💧 Pompe ACTIVEE (GPIO17)", "success")
        else:
            self.lbl_pompe.configure(text="● ARRÊT", fg=C["rouge"])
            self.btn_pompe.configure(text="▶️  DEMARRER")
            btn_style(self.btn_pompe, bg=C["bleu"], size=10)
            self.console.log_event("💧 Pompe desactivee", "warning")

        # Sauvegarde Firebase
        try:
            db.child("actions").child(self.uid).push({
                "type": "pompe",
                "etat": etat,
                "plante": self.plante_active["nom"] if self.plante_active else "N/A",
                "timestamp": datetime.now().isoformat()
            })
        except Exception as e:
            print(f"Firebase save error: {e}")

