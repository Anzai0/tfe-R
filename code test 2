    def _update_loop(self):
        """Boucle mise à jour capteurs"""
        while self.running:
            try:
                self.capteurs_data["temperature"] = 24 + (5 * (time.time() % 10) / 10)
                self.capteurs_data["humidite_air"] = 65
                self.capteurs_data["humidite_sol"] = 50
                self.capteurs_data["pluie"] = False
            except:
                pass

            self.after(0, self._render_capteurs)
            time.sleep(2)

    def _render_capteurs(self):
        """Met à jour affichage capteurs"""
        t = self.capteurs_data.get("temperature", 0)
        h = self.capteurs_data.get("humidite_air", 0)
        s = self.capteurs_data.get("humidite_sol", 0)
        p = self.capteurs_data.get("pluie", False)

        configs = {
            "temp": (f"{t:.1f}°C", C["rouge"] if t > 30 else C["vert"], min(t/40, 1)),
            "hum": (f"{h:.0f}%", C["orange"] if h < 40 else C["vert"], h/100),
            "sol": (f"{s:.0f}%", C["rouge"] if s < 30 else C["vert"], s/100),
            "pluie": ("🌧️ Oui" if p else "Non", C["cyan"] if p else C["gris"], 1 if p else 0.1),
        }
        
        for key, (txt, color, ratio) in configs.items():
            if key in self._vals:
                lbl, bar = self._vals[key]
                lbl.configure(text=txt, fg=color)
                bar.configure(bg=color)
                bar.place(relwidth=min(max(ratio, 0), 1))

        self.lbl_statut.configure(text=f"🔄 {time.strftime('%H:%M:%S')}", fg=C["gris"])

        # VERIFIE REGLES (ALERTE SI DEPASSEMENT)
        if self.plante_active:
            p = self.plante_active
            if t > p["temp_max"]:
                self.console.log_event(f"⚠️  TEMP trop haute ({t:.0f}°C > {p['temp_max']}°C)", "warning")
                gpio.buzz(0.3)
            if h < p["humidite_min"]:
                self.console.log_event(f"⚠️  HUM trop basse ({h:.0f}% < {p['humidite_min']}%)", "warning")

    def _card(self, parent, titre=""):
        wrapper = tk.Frame(parent, bg=C["accent"], pady=1, padx=1)
        wrapper.pack(fill="x", padx=12, pady=8)

        card = tk.Frame(wrapper, bg=C["carte"], padx=18, pady=16)
        card.pack(fill="x")

        if titre:
            tk.Label(
                card,
                text=titre,
                font=("Segoe UI", 11, "bold"),
                bg=C["carte"],
                fg=C["accent"]
            ).pack(anchor="w", pady=(0, 8))
            tk.Frame(card, bg=C["gris2"], height=1).pack(fill="x", pady=(0, 10))

        return card


