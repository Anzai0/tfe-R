        # CARD PRINCIPALE
        card = tk.Frame(wrapper, bg=C["carte"], pady=35, padx=40)
        card.pack(fill="x")

        # ONGLETS MODERNES
        tab_frame = tk.Frame(card, bg=C["carte2"], pady=8, padx=8, relief="flat")
        tab_frame.pack(fill="x", pady=(0, 28))

        self.btn_conn = tk.Button(
            tab_frame,
            text="🔐 CONNEXION",
            command=lambda: self._mode("connexion"),
            pady=10,
            padx=20,
            relief="flat",
            font=("Segoe UI", 11, "bold"),
            cursor="hand2"
        )
        self.btn_insc = tk.Button(
            tab_frame,
            text="✨ INSCRIPTION",
            command=lambda: self._mode("inscription"),
            pady=10,
            padx=20,
            relief="flat",
            font=("Segoe UI", 11, "bold"),
            cursor="hand2"
        )
        self.btn_conn.pack(side="left", fill="x", expand=True, padx=4)
        self.btn_insc.pack(side="left", fill="x", expand=True, padx=4)

        # EMAIL
        tk.Label(
            card,
            text="📧 EMAIL",
            font=("Segoe UI", 10, "bold"),
            bg=C["carte"],
            fg=C["accent"]
        ).pack(anchor="w")
        self.entry_email = tk.Entry(card)
        entry_style(self.entry_email)
        self.entry_email.pack(fill="x", pady=(6, 16), ipady=11)

        # PASSWORD
        tk.Label(
            card,
            text="🔒 MOT DE PASSE",
            font=("Segoe UI", 10, "bold"),
            bg=C["carte"],
            fg=C["accent"]
        ).pack(anchor="w")
        self.entry_mdp = tk.Entry(card, show="●")
        entry_style(self.entry_mdp)
        self.entry_mdp.pack(fill="x", pady=(6, 20), ipady=11)

        # BOUTON ACTION
        self.btn_action = tk.Button(
            card,
            text="🚀 SE CONNECTER",
            command=self._action,
            pady=13
        )
        btn_style(self.btn_action, size=12)
        self.btn_action.pack(fill="x")

        # MESSAGE ERREUR
        self.lbl_msg = tk.Label(
            card,
            text="",
            font=("Segoe UI", 9),
            bg=C["carte"],
            fg=C["rouge"]
        )
        self.lbl_msg.pack(pady=(12, 0))

        # FOOTER
        tk.Label(
            wrapper,
            text="v2.1 | IoT Greenhouse | 2024",
            font=("Segoe UI", 8),
            bg=C["fond"],
            fg=C["gris2"]
        ).pack(pady=(20, 0))

        self._mode("connexion")

    def _mode(self, mode):
        self.mode_var = mode
        if mode == "connexion":
            self.btn_conn.configure(bg=C["accent"], fg=C["btn_texte"])
            self.btn_insc.configure(bg=C["carte3"], fg=C["gris"])
            self.btn_action.configure(text="🚀 SE CONNECTER")
        else:
            self.btn_insc.configure(bg=C["accent"], fg=C["btn_texte"])
            self.btn_conn.configure(bg=C["carte3"], fg=C["gris"])
            self.btn_action.configure(text="✨ CREER UN COMPTE")

    def _action(self):
        email = self.entry_email.get().strip()
        mdp = self.entry_mdp.get().strip()
        
        if not email or not mdp:
            self.lbl_msg.configure(text="⚠️  Remplissez tous les champs")
            return

        txt = self.btn_action.cget("text")
        self.btn_action.configure(text="⏳ Chargement...", state="disabled")
        self.lbl_msg.configure(text="")

        def tache():
            try:
                if self.mode_var == "connexion":
                    user = auth.sign_in_with_email_and_password(email, mdp)
                else:
                    user = auth.create_user_with_email_and_password(email, mdp)
                uid = user["localId"]
                self.after(0, lambda: self.on_connexion(uid, email))
            except Exception as e:
                s = str(e)
                msg = "❌ Email ou mot de passe incorrect"
                if "EMAIL_EXISTS" in s:
                    msg = "⚠️  Email deja utilise"
                elif "WEAK_PASSWORD" in s:
                    msg = "⚠️  Mot de passe trop court (6 caracteres min)"
                elif "INVALID_EMAIL" in s:
                    msg = "❌ Email invalide"
                self.after(0, lambda: self.lbl_msg.configure(text=msg))
                self.after(0, lambda: self.btn_action.configure(text=txt, state="normal"))

        threading.Thread(target=tache, daemon=True).start()


