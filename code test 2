class App:
    def __init__(self):
        self.fen = tk.Tk()
        self.fen.title("🌿 Serre Connectee v2.4")
        self.fen.configure(bg=C["fond"])
        self.fen.geometry("1600x1000")
        self.fen.minsize(1200, 700)
        self.page = None
        self._connexion()

    def _connexion(self):
        if self.page:
            self.page.destroy()
        self.page = PageConnexion(self.fen, self._dashboard)
        self.page.pack(fill="both", expand=True)

    def _dashboard(self, uid, email):
        if self.page:
            self.page.destroy()
        self.page = PageDashboard(self.fen, uid, email, self._connexion)
        self.page.pack(fill="both", expand=True)

    def lancer(self):
        self.fen.mainloop()
        gpio.cleanup()

if __name__ == "__main__":
    App().lancer()
