        self.lbl_compteur.configure(text=f"📊 {len(self.plantes)}/3")

        # Update bouton
        if len(self.plantes) >= 3:
            self.btn_add_plante.configure(state="disabled", bg=C["gris2"], text="🔒 MAX ATTEINT")
            self.btn_add_plante.configure(cursor="arrow")
        else:
            self.btn_add_plante.configure(state="normal", bg=C["bleu"], text="➕ AJOUTER PLANTE")
            btn_style(self.btn_add_plante, bg=C["bleu"])
            self.btn_add_plante.configure(cursor="hand2")

        if not self.plantes:
            tk.Label(
                self.frame_liste,
                text="🌍 Aucune plante - cliquez sur AJOUTER",
                font=("Segoe UI", 10, "italic"),
                bg=C["carte"],
                fg=C["gris"]
            ).pack(pady=20)
            return

        for idx, plante in enumerate(self.plantes):
            actif = self.plante_active and self.plante_active["nom"] == plante["nom"]
            border_color = C["accent"] if actif else C["gris2"]

            c = tk.Frame(self.frame_liste, bg=border_color, pady=2, padx=2)
            c.pack(fill="x", pady=6)
            inner = tk.Frame(c, bg=C["carte3"] if actif else C["carte2"], padx=16, pady=14)
            inner.pack(fill="x")

            top = tk.Frame(inner, bg=inner.cget("bg"))
            top.pack(fill="x")

            # Numero + nom
            tk.Label(
                top,
                text=f"🌿 [{idx+1}/3] {plante['nom']}",
                font=("Segoe UI", 12, "bold"),
                bg=inner.cget("bg"),
                fg=C["accent"] if actif else C["texte"]
            ).pack(side="left")

            if actif:
                tk.Label(
                    top,
                    text="✓ ACTIVE",
                    font=("Segoe UI", 8, "bold"),
                    bg=inner.cget("bg"),
                    fg=C["vert"]
                ).pack(side="left", padx=(10, 0))

            info_frame = tk.Frame(inner, bg=inner.cget("bg"))
            info_frame.pack(fill="x", pady=(10, 0))

            for label, val, unit, ico in [
                ("Temp max", plante["temp_max"], "°C", "🌡️"),
                ("Hum min", plante["humidite_min"], "%", "💨"),
                ("Eau min", plante["eau_min"], "%", "💧"),
            ]:
                chip = tk.Frame(info_frame, bg=C["gris2"], padx=10, pady=5)
                chip.pack(side="left", padx=(0, 8))
                tk.Label(
                    chip,
                    text=f"{ico} {label}: {val}{unit}",
                    font=("Segoe UI", 8),
                    bg=C["gris2"],
                    fg=C["texte"]
                ).pack()

            btn_frame = tk.Frame(inner, bg=inner.cget("bg"))
            btn_frame.pack(fill="x", pady=(10, 0))

            if not actif:
                b_sel = tk.Button(
                    btn_frame,
                    text="📍 SELECTIONNER",
                    command=lambda p=plante: self._selectionner(p),
                    pady=6,
                    padx=10
                )
                btn_style(b_sel, bg=C["bleu"])
                b_sel.pack(side="left", padx=(0, 6))

            b_sup = tk.Button(
                btn_frame,
                text="🗑️  SUPPRIMER",
                command=lambda p=plante: self._supprimer(p),
                pady=6,
                padx=10
            )
            btn_style(b_sup, bg=C["rouge"], fg=C["texte"])
            b_sup.pack(side="right")

    def _popup_plante(self):
        """Popup pour ajouter une plante"""
        if len(self.plantes) >= 3:
            messagebox.showwarning("Limite", "🔒 Maximum 3 plantes !")
            return

        pop = tk.Toplevel(self)
        pop.title("➕ Nouvelle plante")
        pop.configure(bg=C["fond"])
        pop.geometry("480x550")
        pop.resizable(False, False)
        pop.grab_set()

        tk.Label(
            pop,
            text="🌱 NOUVELLE PLANTE",
            font=("Segoe UI", 15, "bold"),
            bg=C["fond"],
            fg=C["accent"]
        ).pack(pady=(30, 8))

        tk.Label(
            pop,
            text="Configurez les parametres de votre plante",
            font=("Segoe UI", 9),
            bg=C["fond"],
            fg=C["gris"]
        ).pack()

        gradient_frame(pop)

        card = tk.Frame(pop, bg=C["carte"], padx=30, pady=30)
        card.pack(fill="x", padx=25, pady=20)

        champs = [
            ("🌿 NOM DE LA PLANTE", "nom", ""),
            ("🌡️  TEMPERATURE MAX (°C)", "temp_max", "30"),
            ("💨 HUMIDITE MINI (%)", "humidite_min", "50"),
            ("💧 EAU MINI (%)", "eau_min", "30"),
        ]
        entries = {}
        
        for label, key, default in champs:
            tk.Label(
                card,
                text=label,
                font=("Segoe UI", 10, "bold"),
                bg=C["carte"],
                fg=C["accent"]
            ).pack(anchor="w")
            e = tk.Entry(card)
            entry_style(e)
            e.insert(0, default)
            e.pack(fill="x", pady=(6, 14), ipady=10)
            entries[key] = e

        lbl_err = tk.Label(
            card,
            text="",
            font=("Segoe UI", 9),
            bg=C["carte"],
            fg=C["rouge"]
        )
        lbl_err.pack()

        def sauvegarder():
            nom = entries["nom"].get().strip()
            if not nom:
                lbl_err.configure(text="❌ Le nom est obligatoire")
                return
            if any(p["nom"].lower() == nom.lower() for p in self.plantes):
                lbl_err.configure(text="⚠️  Cette plante existe deja")
                return
            try:
                tm = float(entries["temp_max"].get())
                hm = float(entries["humidite_min"].get())
                em = float(entries["eau_min"].get())
            except:
                lbl_err.configure(text="❌ Valeurs numeriques invalides")
                return

            def save_firebase():
                try:
                    db.child("plantes").child(self.uid).child(nom).set({
                        "temp_max": tm,
                        "humidite_min": hm,
                        "eau_min": em
                    })
                    self.plantes.append({
                        "nom": nom,
                        "temp_max": tm,
                        "humidite_min": hm,
                        "eau_min": em
                    })
                    if not self.plante_active:
                        self.plante_active = self.plantes[0]
                    self.after(0, self._afficher_plantes)
                    
                    self.console.log_event(f"Plante '{nom}' ajoutee [✓]", "success")
                    
                    pop.destroy()
                except Exception as e:
                    self.after(0, lambda: lbl_err.configure(text=f"❌ Erreur: {e}"))
                    self.console.log_event(f"Erreur ajout plante: {e}", "error")

            threading.Thread(target=save_firebase, daemon=True).start()

        btn = tk.Button(card, text="✅ AJOUTER LA PLANTE", command=sauvegarder, pady=12)
        btn_style(btn, size=11)
        btn.pack(fill="x", pady=(10, 0))

    def _selectionner(self, plante):
        """Selectionne une plante"""
        self.plante_active = plante
        self._afficher_plantes()
        self.console.log_event(f"Plante '{plante['nom']}' selectionnee", "info")

    def _supprimer(self, plante):
        """Supprime une plante"""
        if not messagebox.askyesno("Supprimer", f"Supprimer {plante['nom']} ?"):
            return
        
        def delete_firebase():
            try:
                db.child("plantes").child(self.uid).child(plante["nom"]).remove()
                self.plantes = [p for p in self.plantes if p["nom"] != plante["nom"]]
                if self.plante_active and self.plante_active["nom"] == plante["nom"]:
                    self.plante_active = self.plantes[0] if self.plantes else None
                self.after(0, self._afficher_plantes)
                
                self.console.log_event(f"Plante '{plante['nom']}' supprimee", "warning")
            except Exception as e:
                self.console.log_event(f"Erreur suppression: {e}", "error")

        threading.Thread(target=delete_firebase, daemon=True).start()

    def _toggle_pompe(self):
        """Active/desactive la pompe"""
        self.pompe_active = not self.pompe_active
        if self.pompe_active:
            self.lbl_pompe.configure(text="● MARCHE", fg=C["vert"])
            self.btn_pompe.configure(text="⏹️  ARRETER", bg=C["rouge"])
            self.console.log_event("Pompe activee ✓", "pompe")
        else:
            self.lbl_pompe.configure(text="● ARRÊT", fg=C["rouge"])
            self.btn_pompe.configure(text="▶️  ACTIVER", bg=C["vert"])
            self.console.log_event("Pompe desactivee ✗", "pompe")
        self._cmd("pompe", self.pompe_active)

    def _toggle_ventilo(self):
        """Active/desactive le ventilateur"""
        self.ventilo_actif = not self.ventilo_actif
        if self.ventilo_actif:
            self.lbl_ventilo.configure(text="● MARCHE", fg=C["vert"])
            self.btn_ventilo.configure(text="⏹️  ARRETER", bg=C["rouge"])
            self.console.log_event("Ventilateur active ✓", "ventilo")
        else:
            self.lbl_ventilo.configure(text="● ARRÊT", fg=C["rouge"])
            self.btn_ventilo.configure(text="▶️  ACTIVER", bg=C["vert"])
            self.console.log_event("Ventilateur desactive ✗", "ventilo")
        self._cmd("ventilateur", self.ventilo_actif)

    def _cmd(self, appareil, etat):
        """Envoie une commande"""
        def cmd_firebase():
            try:
                db.child("commandes").child(self.uid).update({appareil: etat})
            except:
                pass
        threading.Thread(target=cmd_firebase, daemon=True).start()

    def _rafraichir(self):
        """Rafraichit les donnees"""
        if not self.loading:
            self.after(0, self._show_sections)
            self._afficher_plantes()

        def tache():
            try:
                response = db.child("capteurs").child(self.uid).get()
                if response.val():
                    d = response.val()
                    self.after(0, self._update, d)
            except Exception as e:
                pass
            self.after(5000, self._rafraichir)
        
        threading.Thread(target=tache, daemon=True).start()

    def _update(self, d):
        """Met a jour l'affichage"""
        temp = d.get("temperature", "--")
        hum = d.get("humidite_air", "--")
        sol = d.get("humidite_sol", "--")
        pluie = d.get("pluie", False)

        configs = {
            "temp": (f"{temp}°C", C["rouge"] if isinstance(temp, (int, float)) and temp > 30 else C["vert"], 0.7),
            "hum": (f"{hum}%", C["orange"] if isinstance(hum, (int, float)) and hum < 40 else C["vert"], hum/100 if isinstance(hum, (int, float)) else 0.5),
            "sol": (f"{sol}%", C["rouge"] if isinstance(sol, (int, float)) and sol < 30 else C["vert"], sol/100 if isinstance(sol, (int, float)) else 0.5),
            "pluie": ("🌧️ Oui" if pluie else "Non", C["bleu"] if pluie else C["gris"], 1.0 if pluie else 0.1),
        }
        
        for key, (txt, color, ratio) in configs.items():
            if key in self._vals:
                lbl, bar = self._vals[key]
                lbl.configure(text=txt, fg=color)
                bar.configure(bg=color)
                bar.place(relwidth=min(max(ratio, 0), 1))

        self.lbl_statut.configure(
            text=f"🔄 MAJ: {time.strftime('%H:%M:%S')}",
            fg=C["gris"]
        )

    def _card(self, parent, titre=""):
        """Cree une carte moderne"""
        wrapper = tk.Frame(parent, bg=C["accent"], pady=2, padx=2)
        wrapper.pack(fill="x", padx=15, pady=10)

        card = tk.Frame(wrapper, bg=C["carte"], padx=20, pady=18)
        card.pack(fill="x")

        if titre:
            tk.Label(
                card,
                text=titre,
                font=("Segoe UI", 12, "bold"),
                bg=C["carte"],
                fg=C["accent"]
            ).pack(anchor="w", pady=(0, 10))
            tk.Frame(card, bg=C["gris2"], height=2).pack(fill="x", pady=(0, 12))

        return card


